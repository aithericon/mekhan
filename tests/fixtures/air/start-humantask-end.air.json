{
  "name": "HumanTask Fixture",
  "places": [
    {
      "id": "p_n-start_ready",
      "name": "Start",
      "type": "state",
      "initial_tokens": [
        {
          "_instance_id": "__INSTANCE_ID__",
          "_created_at": "__TIMESTAMP__"
        }
      ]
    },
    {
      "id": "p_n-ht_input",
      "name": "Review - Input",
      "type": "state",
      "group_id": "grp_n-ht"
    },
    {
      "id": "p_n-ht_active",
      "name": "Review - Active",
      "type": "state",
      "group_id": "grp_n-ht"
    },
    {
      "id": "p_n-ht_signal",
      "name": "Review - Signal",
      "type": "signal",
      "group_id": "grp_n-ht"
    },
    {
      "id": "p_n-ht_output",
      "name": "Review - Output",
      "type": "state",
      "group_id": "grp_n-ht"
    },
    {
      "id": "p_n-end_done",
      "name": "End",
      "type": "terminal"
    }
  ],
  "transitions": [
    {
      "id": "t_n-ht_request",
      "name": "Review - Request",
      "group_id": "grp_n-ht",
      "input_ports": [
        {
          "name": "task",
          "cardinality": "single"
        }
      ],
      "output_ports": [
        {
          "name": "assigned",
          "cardinality": "single"
        }
      ],
      "inputs": [
        {
          "place": "p_n-ht_input",
          "port": "task"
        }
      ],
      "outputs": [
        {
          "port": "assigned",
          "place": "p_n-ht_active"
        }
      ],
      "logic": {
        "type": "effect",
        "handler_id": "human_task",
        "config": {
          "place": "p_n-ht_signal"
        }
      }
    },
    {
      "id": "t_n-ht_finalize",
      "name": "Review - Finalize",
      "group_id": "grp_n-ht",
      "input_ports": [
        {
          "name": "state",
          "cardinality": "single"
        },
        {
          "name": "signal",
          "cardinality": "single"
        }
      ],
      "output_ports": [
        {
          "name": "done",
          "cardinality": "single"
        }
      ],
      "inputs": [
        {
          "place": "p_n-ht_active",
          "port": "state"
        },
        {
          "place": "p_n-ht_signal",
          "port": "signal"
        }
      ],
      "outputs": [
        {
          "port": "done",
          "place": "p_n-ht_output"
        }
      ],
      "guard": {
        "type": "rhai",
        "source": "signal.task_id == state.task_id"
      },
      "logic": {
        "type": "rhai",
        "source": "let d = state; d.approval = signal.approval; #{ done: d }"
      }
    },
    {
      "id": "t_edge_e-1",
      "name": "Start -> Review",
      "input_ports": [
        {
          "name": "input",
          "cardinality": "single"
        }
      ],
      "output_ports": [
        {
          "name": "output",
          "cardinality": "single"
        }
      ],
      "inputs": [
        {
          "place": "p_n-start_ready",
          "port": "input"
        }
      ],
      "outputs": [
        {
          "port": "output",
          "place": "p_n-ht_input"
        }
      ],
      "logic": {
        "type": "rhai",
        "source": "#{ output: input }"
      }
    },
    {
      "id": "t_edge_e-2",
      "name": "Review -> End",
      "input_ports": [
        {
          "name": "input",
          "cardinality": "single"
        }
      ],
      "output_ports": [
        {
          "name": "output",
          "cardinality": "single"
        }
      ],
      "inputs": [
        {
          "place": "p_n-ht_output",
          "port": "input"
        }
      ],
      "outputs": [
        {
          "port": "output",
          "place": "p_n-end_done"
        }
      ],
      "logic": {
        "type": "rhai",
        "source": "#{ output: input }"
      }
    }
  ],
  "groups": [
    {
      "id": "grp_n-ht",
      "name": "Review"
    }
  ],
  "definitions": {}
}
