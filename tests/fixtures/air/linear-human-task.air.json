{
  "name": "Linear Human Task",
  "places": [
    {
      "id": "p_start-1_ready",
      "name": "Start",
      "type": "state",
      "initial_tokens": [
        {
          "_instance_id": "__INSTANCE_ID__",
          "_created_at": "__TIMESTAMP__"
        }
      ]
    },
    {
      "id": "p_ht-1_input",
      "name": "Review Task - Input",
      "type": "state",
      "group_id": "grp_ht-1"
    },
    {
      "id": "p_ht-1_active",
      "name": "Review Task - Active",
      "type": "state",
      "group_id": "grp_ht-1"
    },
    {
      "id": "p_ht-1_signal",
      "name": "Review Task - Signal",
      "type": "signal",
      "group_id": "grp_ht-1"
    },
    {
      "id": "p_ht-1_output",
      "name": "Review Task - Output",
      "type": "state",
      "group_id": "grp_ht-1"
    },
    {
      "id": "p_end-1_done",
      "name": "End",
      "type": "terminal"
    }
  ],
  "transitions": [
    {
      "id": "t_ht-1_request",
      "name": "Review Task - Request",
      "group_id": "grp_ht-1",
      "input_ports": [
        {
          "name": "task",
          "cardinality": "single"
        }
      ],
      "output_ports": [
        {
          "name": "assigned",
          "cardinality": "single"
        }
      ],
      "inputs": [
        {
          "place": "p_ht-1_input",
          "port": "task"
        }
      ],
      "outputs": [
        {
          "port": "assigned",
          "place": "p_ht-1_active"
        }
      ],
      "logic": {
        "type": "effect",
        "handler_id": "human_task",
        "config": {
          "place": "p_ht-1_signal"
        }
      }
    },
    {
      "id": "t_ht-1_finalize",
      "name": "Review Task - Finalize",
      "group_id": "grp_ht-1",
      "input_ports": [
        {
          "name": "state",
          "cardinality": "single"
        },
        {
          "name": "signal",
          "cardinality": "single"
        }
      ],
      "output_ports": [
        {
          "name": "done",
          "cardinality": "single"
        }
      ],
      "inputs": [
        {
          "place": "p_ht-1_active",
          "port": "state"
        },
        {
          "place": "p_ht-1_signal",
          "port": "signal"
        }
      ],
      "outputs": [
        {
          "port": "done",
          "place": "p_ht-1_output"
        }
      ],
      "guard": {
        "type": "rhai",
        "source": "signal.task_id == state.task_id"
      },
      "logic": {
        "type": "rhai",
        "source": "let d = state; d.approved = signal.approved; #{ done: d }"
      }
    },
    {
      "id": "t_edge_e1",
      "name": "Start -> Review Task",
      "input_ports": [
        {
          "name": "input",
          "cardinality": "single"
        }
      ],
      "output_ports": [
        {
          "name": "output",
          "cardinality": "single"
        }
      ],
      "inputs": [
        {
          "place": "p_start-1_ready",
          "port": "input"
        }
      ],
      "outputs": [
        {
          "port": "output",
          "place": "p_ht-1_input"
        }
      ],
      "logic": {
        "type": "rhai",
        "source": "#{ output: input }"
      }
    },
    {
      "id": "t_edge_e2",
      "name": "Review Task -> End",
      "input_ports": [
        {
          "name": "input",
          "cardinality": "single"
        }
      ],
      "output_ports": [
        {
          "name": "output",
          "cardinality": "single"
        }
      ],
      "inputs": [
        {
          "place": "p_ht-1_output",
          "port": "input"
        }
      ],
      "outputs": [
        {
          "port": "output",
          "place": "p_end-1_done"
        }
      ],
      "logic": {
        "type": "rhai",
        "source": "#{ output: input }"
      }
    }
  ],
  "groups": [
    {
      "id": "grp_ht-1",
      "name": "Review Task"
    }
  ],
  "definitions": {}
}
