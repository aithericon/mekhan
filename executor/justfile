# Shared cargo recipes (build/check/fmt/lint/test/test-crate/clean).
# executor's `build` historically targets the whole workspace.
cargo_scope := "--workspace"
import '../just/cargo.just'

# List all available recipes
default:
    @just --list

# Run the executor service
run:
    cargo run -p aithericon-executor-service

# Run with debug logging
run-debug:
    RUST_LOG=debug cargo run -p aithericon-executor-service

# Launch the Surya executor pool (Item 5 of sub-phase 2.2b). Spawns the
# managed Surya subprocess from .dev/surya-venv/ (run `just
# surya-venv-setup` first if absent), binds /v1/healthz + /v1/ocr/extract
# on AITHERICON_EXECUTOR_SURYA_POOL_PORT (default 3302), and registers
# with cloud-layer-capability-routing. Fail-closed if CLOUD_LAYER_JWT_SECRET
# is unset or the subprocess can't start.
run-executor-surya-pool:
    cargo run -p aithericon-executor-surya --bin aithericon-executor-surya-pool

# Start NATS JetStream via Docker.
# Standalone container (own port 4222, default in executor config) — the
# executor workspace ships no docker-compose, so unlike engine/root (which
# delegate to `docker compose`) it runs NATS directly. Image tag pinned to
# nats:2.12-alpine to match the engine/root compose; only the run mechanism
# (standalone vs compose) differs.
nats-up:
    docker run -d --name executor-nats -p 4222:4222 nats:2.12-alpine -js

# Stop NATS
nats-down:
    docker rm -f executor-nats

# Subscribe to executor status updates
nats-subscribe:
    nats sub 'executor.status.>'

# Run integration tests (requires Docker)
test-integration:
    cargo test -p aithericon-executor-service --tests

# Generate Python gRPC stubs from proto (uses a temp venv for grpcio-tools)
gen-python-proto:
    #!/usr/bin/env bash
    set -euo pipefail
    VENV="$(mktemp -d)/proto-venv"
    python3 -m venv "$VENV"
    "$VENV/bin/pip" install -q grpcio-tools
    "$VENV/bin/python" -m grpc_tools.protoc \
        -Icrates/executor-ipc/proto \
        --python_out=packages/aithericon-sdk/src/aithericon/_proto \
        --grpc_python_out=packages/aithericon-sdk/src/aithericon/_proto \
        executor_sidecar.proto
    # Fix absolute import to package-relative
    sed -i '' 's/^import executor_sidecar_pb2/from aithericon._proto import executor_sidecar_pb2/' \
        packages/aithericon-sdk/src/aithericon/_proto/executor_sidecar_pb2_grpc.py
    rm -rf "$VENV"
    echo "Python proto stubs generated"

# ---------------------------------------------------------------------------
# Surya OCR (sub-phase 2.2b)
# ---------------------------------------------------------------------------

# Create / refresh the Surya venv under .dev/surya-venv/. First invocation
# installs PyTorch + surya-ocr + transformers + fastapi + uvicorn into the
# venv via `uv pip install -e`. The FIRST actual Surya invocation (NOT this
# recipe) downloads ~1-2GB of model weights from HuggingFace into the venv's
# ~/.cache/huggingface/hub/ — operators should pre-warm by running this
# recipe + invoking the wrapper once before relying on the 120s readiness
# timeout in production.
#
# License footgun: Surya is GPL-3.0 + modified OpenRAIL-M weights with $2M
# revenue/funding commercial-license threshold (workstream #71). Subprocess
# process-isolation contains GPL-3.0 — the executor binary stays Apache-2.0.
surya-venv-setup:
    @echo "==> Creating Surya venv at .dev/surya-venv/"
    @mkdir -p .dev
    @if [ ! -d .dev/surya-venv ]; then \
        uv venv .dev/surya-venv --python 3.11 ; \
    else \
        echo "    .dev/surya-venv already exists; reusing." ; \
    fi
    @echo "==> Installing surya-pool-server package (Apache-2.0 wrapper) + deps"
    VIRTUAL_ENV=.dev/surya-venv uv pip install -e crates/executor-surya/python
    @echo "==> Surya venv ready at .dev/surya-venv/bin/python"
    @echo "    First Surya invocation will download ~1-2GB of models (5-15 min cold)."
    @echo "    To pre-warm: cd .dev/surya-venv && bin/python -m surya_pool_server --port 7160"

# ---------------------------------------------------------------------------
# nsjail sandbox e2e (docs/sandbox.md, phased build step 4)
# ---------------------------------------------------------------------------

# Image tag for the sandbox e2e runtime. The test harness
# (crates/executor-service/tests/sandbox.rs, gated TEST_SANDBOX=1) boots THIS
# tag via testcontainers, so the recipe and the test must agree on the name.
sandbox_test_image := env_var_or_default("SANDBOX_TEST_IMAGE", "aithericon-executor-sandbox-test:latest")

# Cross-compile the Linux executor + assemble the nsjail+python+nix e2e image.
#
# REUSES the slurm-up zigbuild path verbatim (just/dev.just::slurm-up step 2):
# the executor can't run nsjail on macOS, so we cross-compile a Linux x86_64
# binary with cargo-zigbuild and COPY it into Dockerfile.sandbox-test. Same
# toolchain, same target triple, same trimmed feature set as slurm-up (python +
# http + opendal-s3 + url-inputs — docker/file-ops are dropped: docker is
# meaningless inside the container and file-ops pulls libnetcdf+libhdf5 cross
# system libs we don't have and the sandbox e2e doesn't exercise).
#
# Does NOT run a heavy build by default beyond zigbuild + docker build. After
# this completes, run the e2e with:
#   TEST_SANDBOX=1 cargo test -p aithericon-executor-service --test sandbox
sandbox-test-image:
    #!/usr/bin/env bash
    set -euo pipefail

    # 1. cargo-zigbuild is the cross toolchain (same as slurm-up).
    command -v cargo-zigbuild >/dev/null 2>&1 || {
      echo "✗ cargo-zigbuild not on PATH — cargo install cargo-zigbuild" >&2; exit 1; }
    command -v docker >/dev/null 2>&1 || {
      echo "✗ docker not on PATH" >&2; exit 1; }

    # 2. Pick the Linux target to MATCH the Docker engine's arch, so nsjail runs
    #    natively (under qemu emulation its namespace/seccomp ops misbehave).
    #    Auto-detect from the host (Docker Desktop's VM follows host arch);
    #    override with SANDBOX_TARGET for cross-arch CI.
    target="${SANDBOX_TARGET:-}"
    if [ -z "$target" ]; then
      case "$(uname -m)" in
        arm64|aarch64) target="aarch64-unknown-linux-gnu" ;;
        *)             target="x86_64-unknown-linux-gnu" ;;
      esac
    fi
    case "$target" in
      aarch64-*) platform="linux/arm64" ;;
      *)         platform="linux/amd64" ;;
    esac

    # Cross-compile the executor for $target. Mirrors the slurm-up feature set;
    # the sandbox path lives in executor-process / executor-python (python
    # feature).
    echo "▶ cross-compiling executor for $target (sandbox e2e features)…"
    cargo zigbuild -p aithericon-executor-service \
       --features "python,http,http-cancel,opendal-s3,url-inputs" \
       --target "$target"
    exec_bin="target/$target/debug/aithericon-executor-service"
    if [ ! -f "$exec_bin" ]; then
      echo "✗ Linux executor binary not found at $exec_bin" >&2; exit 1; fi

    # 3. Build the image for the matching platform. Build context = the executor
    #    workspace root so both the binary (EXECUTOR_BIN) and
    #    packages/aithericon-sdk are reachable.
    echo "▶ docker build {{sandbox_test_image}} ($platform; nsjail + python3 + nix)…"
    docker build \
      --platform "$platform" \
      -f Dockerfile.sandbox-test \
      --build-arg EXECUTOR_BIN="$exec_bin" \
      -t {{sandbox_test_image}} \
      .
    echo "  ✓ {{sandbox_test_image}} built ($platform, binary: $exec_bin)"
    echo "    Run the e2e: TEST_SANDBOX=1 cargo test -p aithericon-executor-service --test sandbox"
