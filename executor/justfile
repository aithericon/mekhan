# List all available recipes
default:
    @just --list

# Build all crates
build:
    cargo build --workspace

# Check all crates
check:
    cargo check --workspace

# Format all code
fmt:
    cargo fmt --all

# Lint all code
lint:
    cargo clippy --workspace -- -D warnings

# Run unit tests
test:
    cargo test --workspace

# Run a specific crate's tests
test-crate name:
    cargo test -p {{name}}

# Run the executor service
run:
    cargo run -p aithericon-executor-service

# Run with debug logging
run-debug:
    RUST_LOG=debug cargo run -p aithericon-executor-service

# Launch the Surya executor pool (Item 5 of sub-phase 2.2b). Spawns the
# managed Surya subprocess from .dev/surya-venv/ (run `just
# surya-venv-setup` first if absent), binds /v1/healthz + /v1/ocr/extract
# on AITHERICON_EXECUTOR_SURYA_POOL_PORT (default 3302), and registers
# with cloud-layer-capability-routing. Fail-closed if CLOUD_LAYER_JWT_SECRET
# is unset or the subprocess can't start.
run-executor-surya-pool:
    cargo run -p aithericon-executor-surya --bin aithericon-executor-surya-pool

# Start NATS JetStream via Docker
nats-up:
    docker run -d --name executor-nats -p 4222:4222 nats:latest -js

# Stop NATS
nats-down:
    docker rm -f executor-nats

# Subscribe to executor status updates
nats-subscribe:
    nats sub 'executor.status.>'

# Run integration tests (requires Docker)
test-integration:
    cargo test -p aithericon-executor-service --tests

# Generate Python gRPC stubs from proto (uses a temp venv for grpcio-tools)
gen-python-proto:
    #!/usr/bin/env bash
    set -euo pipefail
    VENV="$(mktemp -d)/proto-venv"
    python3 -m venv "$VENV"
    "$VENV/bin/pip" install -q grpcio-tools
    "$VENV/bin/python" -m grpc_tools.protoc \
        -Icrates/executor-ipc/proto \
        --python_out=packages/aithericon-sdk/src/aithericon/_proto \
        --grpc_python_out=packages/aithericon-sdk/src/aithericon/_proto \
        executor_sidecar.proto
    # Fix absolute import to package-relative
    sed -i '' 's/^import executor_sidecar_pb2/from aithericon._proto import executor_sidecar_pb2/' \
        packages/aithericon-sdk/src/aithericon/_proto/executor_sidecar_pb2_grpc.py
    rm -rf "$VENV"
    echo "Python proto stubs generated"

# ---------------------------------------------------------------------------
# Surya OCR (sub-phase 2.2b)
# ---------------------------------------------------------------------------

# Create / refresh the Surya venv under .dev/surya-venv/. First invocation
# installs PyTorch + surya-ocr + transformers + fastapi + uvicorn into the
# venv via `uv pip install -e`. The FIRST actual Surya invocation (NOT this
# recipe) downloads ~1-2GB of model weights from HuggingFace into the venv's
# ~/.cache/huggingface/hub/ — operators should pre-warm by running this
# recipe + invoking the wrapper once before relying on the 120s readiness
# timeout in production.
#
# License footgun: Surya is GPL-3.0 + modified OpenRAIL-M weights with $2M
# revenue/funding commercial-license threshold (workstream #71). Subprocess
# process-isolation contains GPL-3.0 — the executor binary stays Apache-2.0.
surya-venv-setup:
    @echo "==> Creating Surya venv at .dev/surya-venv/"
    @mkdir -p .dev
    @if [ ! -d .dev/surya-venv ]; then \
        uv venv .dev/surya-venv --python 3.11 ; \
    else \
        echo "    .dev/surya-venv already exists; reusing." ; \
    fi
    @echo "==> Installing surya-pool-server package (Apache-2.0 wrapper) + deps"
    VIRTUAL_ENV=.dev/surya-venv uv pip install -e crates/executor-surya/python
    @echo "==> Surya venv ready at .dev/surya-venv/bin/python"
    @echo "    First Surya invocation will download ~1-2GB of models (5-15 min cold)."
    @echo "    To pre-warm: cd .dev/surya-venv && bin/python -m surya_pool_server --port 7160"

# Clean build artifacts
clean:
    cargo clean
