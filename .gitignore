# Rust
target/
**/target/
Cargo.lock.bak
*.rs.bk

# Node
node_modules/
app/.output/
app/.svelte-kit/
app/build/
# pnpm content-addressable store. Created at the repo root when `pnpm install`
# runs inside the CI builder over a bind-mounted workspace — the container
# treats CWD-relative `.pnpm-store/` as the store path, so it lands here on
# the host. 20k+ files, 350+ MB — never commit.
.pnpm-store/

# Python
__pycache__/
*.py[cod]

# IDE / OS
.DS_Store
Thumbs.db

# Environment
.env
.env.*
!.env.example
!.env.test

# Test artifacts
test-results/
playwright-report/

# Agent / tooling
.agent_status/
.claude/

# Vite temp files
vite.config.js.timestamp-*
vite.config.ts.timestamp-*

# Nix / direnv
.direnv/
.cache/
# `nix build` result symlinks — anchored to the repo root so the unscoped glob
# doesn't swallow legitimately-named files elsewhere (e.g. docs/.../result-ingest.md).
/result
/result-*

# Local dev stack runtime state (pidfiles, logs, executor work dir)
.dev/

# Local Zitadel bootstrap output (PAT secret + generated config)
deploy/zitadel/pat/*.pat
deploy/zitadel/pat/*.json
mekhan.local.toml
service/mekhan.local.toml

# Per-machine mekhan CLI auth token (sourced by .envrc); never commit
.mekhan.token

# air_snapshots debug sidecars (written only on drift; never tracked)
service/tests/snapshots/air/*.json.new
