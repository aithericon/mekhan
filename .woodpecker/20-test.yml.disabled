# =============================================================================
# Test pool — unit tests, rust + frontend
# =============================================================================
# Modelled on web-platform's GitLab `stage: test` jobs (test-unit-rust,
# test-unit-frontend) — the cheap, fast, no-external-dep half of their test
# suite. Integration tests deliberately excluded (matches web-platform's
# `test-integration-frontend` being commented out) because they need
# docker-compose with Postgres + NATS + Zitadel bootstrap, which is much
# more state to manage in CI than a unit suite is worth.
#
# Wedged between 10-lint and 30-build in the natural ordering:
#   lint (fmt + clippy)  →  test (cargo test + vitest)  →  build (images)
#
# 30-build.yml has `depends_on: [20-test]` so a regression here blocks
# image production for the same commit. Deploy chains off build, so a
# failing test transitively blocks deploy too.
# =============================================================================

when:
  # Auto on main — gates merges by running tests on every push.
  - branch: main
    event: push
  # Manual run from any branch — for spot-checking tests on a feature
  # branch before opening a PR or merging.
  - event: manual

labels:
  role: test
  host: worker-hetzner

steps:
  # cargo test --workspace. Caches cargo registry + target dir on the
  # build runner via the standard CARGO_HOME path the lint + build steps
  # already use, so warm runs only recompile what changed.
  - name: test-rust
    image: forge.aithericon.eu/milanender/mekhan-ci-builder:latest
    pull: true
    environment:
      CARGO_HOME: /var/lib/ci-jobs/cache/cargo
      # Same target dir as build-backend — release vs test profiles use
      # different subdirs under target/, so cargo handles them side by
      # side without invalidating each other.
      CARGO_TARGET_DIR: /var/lib/ci-jobs/cache/target/mekhan
    volumes:
      - /var/lib/ci-jobs/cache:/var/lib/ci-jobs/cache
    commands:
      - just ci::test-rust
    depends_on: []

  # pnpm test (vitest). Same NPM cache path the build step uses so
  # node_modules survives across runs.
  - name: test-frontend-unit
    image: forge.aithericon.eu/milanender/mekhan-ci-builder:latest
    pull: true
    environment:
      NPM_CONFIG_CACHE: /var/lib/ci-jobs/cache/npm
    volumes:
      - /var/lib/ci-jobs/cache:/var/lib/ci-jobs/cache
    commands:
      - just ci::test-frontend-unit
    depends_on: []
