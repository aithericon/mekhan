        "SelectOption": {
          "description": "One choice in a `kind = \"select\"` (or `radio`) field. `value` is what the form submits / what downstream guards compare against; `label` is what the UI renders. Authors typically write `{value, label}`; the deserializer on `TaskField::options` also accepts a bare string and stretches it to `{value: s, label: s}`. Mirror of the same type in `service/src/models/template.rs` — the engine's HumanTask effect handler validates the wire payload against `TaskField`, so the shape must match what the service compiles into AIR.",
          "properties": {
            "label": {
              "type": "string"
            },
            "value": {
              "type": "string"
            }
          },
          "required": [
            "label",
            "value"
          ],
          "type": "object"
