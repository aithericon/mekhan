  "requirements": [
    {
      "category": "human",
      "handler_ids": [
        "human_task"
      ]
    },
    {
      "category": "orchestration",
      "handler_ids": [
        "process_complete",
        "process_start"
      ]
    }
  ],
  "transitions": [
    {
      "guard": {
        "source": "signal.task_id == state.task_id",
        "type": "rhai"
      },
      "id": "t_ask_finalize",
      "input_ports": [
        {
          "cardinality": "single",
          "name": "state",
          "schema_ref": "#/definitions/DynamicToken"
        },
        {
          "cardinality": "single",
          "name": "signal",
          "schema_ref": "#/definitions/DynamicToken"
        }
      ],
      "input_schema": {
        "properties": {
          "DynamicToken": {
            "$ref": "#/definitions/DynamicToken"
          }
        },
        "type": "object"
      },
      "inputs": [
        {
          "place": "p_ask_active",
          "port": "state",
          "weight": 1
        },
        {
          "place": "p_ask_signal",
          "port": "signal",
          "weight": 1
        }
      ],
      "logic": {
        "source": "let result = state; let keys = signal.keys(); for key in keys { result[key] = signal[key]; } #{ done: result }",
        "type": "rhai"
      },
      "name": "Ask Operator - Finalize",
      "output_ports": [
        {
          "cardinality": "single",
          "name": "done",
          "schema_ref": "#/definitions/DynamicToken"
        }
      ],
      "output_schema": {
        "properties": {
          "DynamicToken": {
            "$ref": "#/definitions/DynamicToken"
          }
        },
        "type": "object"
      },
      "outputs": [
        {
          "place": "p_ask_output",
          "port": "done",
          "weight": 1
        }
      ]
    },
    {
      "caused_signals": [
        "p_ask_signal"
      ],
      "effect_config": {
        "place": "p_ask_signal"
      },
      "id": "t_ask_request",
      "input_ports": [
        {
          "cardinality": "single",
          "name": "task",
          "schema_ref": "#/definitions/HumanTaskRequest"
        }
      ],
      "input_schema": {
        "properties": {
          "HumanTaskRequest": {
            "$ref": "#/definitions/HumanTaskRequest"
          }
        },
        "type": "object"
      },
      "inputs": [
        {
          "place": "p_ask_input",
          "port": "task",
          "weight": 1
        }
      ],
