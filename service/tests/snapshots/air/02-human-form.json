    "DynamicToken": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "description": "Dynamic token - untyped JSON data.\n\nUse when you need flexibility and don't want compile-time type checking. Rhai scripts can manipulate these freely.",
      "title": "DynamicToken"
    },
    "EffectError": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "description": "Error token produced by the engine when an effect handler fails.\n\nConstructed in `firing.rs` for every effect transition `_error` port. The `inputs` field contains the original port inputs (dynamic), enabling retry logic to re-queue the original job via `err.inputs.job`.",
      "properties": {
        "error": {
          "description": "Error message from the handler.",
          "type": "string"
        },
        "handler_id": {
          "description": "Handler that failed (e.g., `\"executor_submit\"`).",
          "type": "string"
        },
        "inputs": {
          "description": "Original port inputs (dynamic — shape depends on the transition)."
        },
        "retryable": {
          "description": "Whether the error is retryable.",
          "type": "boolean"
        },
        "transition_id": {
          "description": "Transition ID where the failure occurred.",
          "type": "string"
        }
      },
      "required": [
        "error",
        "handler_id",
        "inputs",
        "retryable",
        "transition_id"
      ],
      "title": "EffectError",
      "type": "object"
    },
    "HumanTaskAssigned": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "description": "Minimal output from the `human_task` effect handler.\n\nThe handler merges all input fields into the output, so you can define a custom output type with extra fields (e.g., `invoice_number`). Use this type when you only need the `task_id` for downstream correlation.",
      "properties": {
        "task_id": {
          "description": "Engine-assigned task ID for correlation with the response signal.",
          "type": "string"
        }
      },
      "required": [
        "task_id"
      ],
      "title": "HumanTaskAssigned",
      "type": "object"
    },
