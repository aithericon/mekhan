				"label": "Iterate on alloc",
				"executionSpec": {
					"backendType": "python",
					"entrypoint": "main.py",
					"config": {
						"python": "python3",
						"requirements": [],
						"virtualenv": false,
						"sdk": true,
						"inherit_env": true,
						"env": {}
					}
				},
				"output": {
					"id": "out",
					"label": "Iter",
					"fields": [
						{ "name": "score", "label": "Score", "kind": "number", "required": true }
					]
				}
			}
		},
		{
			"id": "route",
			"type": "decision",
			"slug": "route",
			"position": { "x": 250, "y": 460 },
