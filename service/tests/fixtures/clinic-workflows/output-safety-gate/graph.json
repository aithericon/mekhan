    {
      "id": "critic",
      "type": "agent",
      "position": { "x": 290, "y": 0 },
      "data": {
        "type": "agent",
        "label": "Safety critic (LLM)",
        "description": "Low-temperature critic. Reads the subject text + the evidence it was supposed to be grounded in, flags overconfident dosing, off-label use, unsupported diagnoses, and claims that don't appear in the evidence. Each flag must carry a verbatim `supporting_text` from the SUBJECT (what looked wrong) — the downstream verifier checks whether that text actually appears in the EVIDENCE.",
        "model": {
          "provider": "internal",
          "model": "qwen3.5:9b",
          "resourceAlias": "internal_pool_router",
          "temperature": 0,
          "maxTokens": 2048
        },
        "userPrompt": "SUBJECT:\n---\n{{ start.subject_text }}\n---\n\nEVIDENCE:\n---\n{{ start.evidence_text }}\n---\n\nReturn JSON: {flags: [{kind, severity, message, supporting_text}]}. severity ∈ {info, warn, critical}. If no issues, return {flags: []}.",
        "systemPrompt": "Du bist ein medizinischer Sicherheits-Kritiker (clinical safety critic). Du erhaeltst (a) einen vom Modell erzeugten Text (subject) und (b) den Quelltext, auf dem dieser hätte basieren sollen (evidence). Markiere jede problematische Aussage im subject:\n- overconfident_dosing: Dosierungsangaben ohne klare Quelle.\n- off_label: Anwendungen ausserhalb der Zulassung.\n- unsupported_diagnosis: Diagnose ohne Belegstelle in evidence.\n- unsupported_claim: Sonstige Aussagen, die nicht in evidence vorkommen.\n- contradicts_evidence: Aussagen, die der evidence direkt widersprechen.\n\nJedes Flag MUSS ein supporting_text-Feld haben, das die problematische Textstelle aus dem subject wortwoertlich zitiert (1-30 Worte). Pruefe selbst nicht, ob die Stelle in der evidence vorkommt — das macht der nachgelagerte Verifier. Sei konservativ: lieber kein Flag als ein erfundenes.",
        "responseFormat": {
          "type": "json_schema",
          "schema": {
            "$ref": "#/definitions/CriticFlags"
          }
        },
        "maxTurns": 1
      }
    },
    {
      "id": "verify",
      "type": "automated_step",
      "position": { "x": 620, "y": 11 },
      "data": {
        "type": "automated_step",
        "label": "Verify flag provenance",
        "description": "For each flag, check whether `supporting_text` actually appears in the SUBJECT (i.e. the critic didn't hallucinate the quote). Mekhan analogue of the clinic's `provenance` step kind with `matcher=hybrid_auto, min_confidence=0.7`. A flag whose quote can't be found is dropped — we'd rather under-block than block on a fabricated quote.",
        "executionSpec": {
          "backendType": "python",
          "entrypoint": "main.py",
          "config": {
            "python": "python3",
            "requirements": [],
            "virtualenv": false,
            "sdk": true,
            "inherit_env": true,
            "env": {}
          }
        },
        "output": {
          "id": "out",
          "label": "Verified flags",
          "fields": [
            {
              "name": "verified_flags",
              "label": "Verified flags",
              "kind": "json",
              "required": true
            },
            {
              "name": "dropped_flags",
              "label": "Dropped flags (couldn't verify quote)",
              "kind": "json",
              "required": true
            },
            {
              "name": "verified_count",
              "label": "Verified count",
              "kind": "number",
              "required": true
            },
            {
              "name": "dropped_count",
              "label": "Dropped count",
              "kind": "number",
              "required": true
            }
          ]
        }
      }
    },
    {
      "id": "decide",
      "type": "automated_step",
      "position": { "x": 930, "y": 11 },
      "data": {
        "type": "automated_step",
        "label": "Safety decision",
        "description": "Aggregate verified flags into a single {pass | warn | block} action. Mirrors online-clinic's `safety_decision_from_flags` compute function. Default rules: any `critical` flag → block; any `warn` flag → warn; else → pass. Returns the reasons[] list for transparency.",
        "executionSpec": {
          "backendType": "python",
          "entrypoint": "main.py",
          "config": {
            "python": "python3",
            "requirements": [],
            "virtualenv": false,
            "sdk": true,
            "inherit_env": true,
            "env": {}
          }
        },
        "output": {
          "id": "out",
          "label": "Decision",
          "fields": [
            {
              "name": "action",
              "label": "Action",
              "kind": "text",
              "required": true
            },
            {
              "name": "reasons",
              "label": "Reasons",
              "kind": "json",
              "required": true
            },
            {
              "name": "critical_count",
              "label": "Critical flags",
              "kind": "number",
              "required": true
            },
            {
              "name": "warn_count",
              "label": "Warn flags",
              "kind": "number",
              "required": true
            }
          ]
        }
      }
    },
