{"openapi":"3.0.3","info":{"title":"Digital Lab - Colored Petri Net API","description":"Event-sourced Petri Net engine for the Aithericon Lab","license":{"name":""},"version":"0.1.0"},"paths":{"/api/command/create-token":{"post":{"tags":["Commands"],"summary":"POST /api/command/create-token","description":"Create a new token at a place.","operationId":"create_token","requestBody":{"content":{"application/json":{"schema":{"$ref":"#/components/schemas/CreateTokenRequest"}}},"required":true},"responses":{"200":{"description":"Token created","content":{"application/json":{"schema":{"$ref":"#/components/schemas/CommandResponse"}}}},"400":{"description":"Cannot create token","content":{"application/json":{"schema":{"$ref":"#/components/schemas/ErrorResponse"}}}}}}},"/api/command/fire/{transition_id}":{"post":{"tags":["Commands"],"summary":"POST /api/command/fire/{transition_id}","description":"Fire a transition.","operationId":"fire_transition","parameters":[{"name":"transition_id","in":"path","description":"Transition ID to fire","required":true,"schema":{"type":"string","format":"uuid"}}],"responses":{"200":{"description":"Transition fired","content":{"application/json":{"schema":{"$ref":"#/components/schemas/CommandResponse"}}}},"400":{"description":"Transition cannot fire","content":{"application/json":{"schema":{"$ref":"#/components/schemas/ErrorResponse"}}}}}}},"/api/command/reset":{"post":{"tags":["Commands"],"summary":"POST /api/command/reset","description":"Reset the event log.","operationId":"reset","responses":{"200":{"description":"Event log reset","content":{"application/json":{"schema":{"$ref":"#/components/schemas/CommandResponse"}}}}}}},"/api/events":{"get":{"tags":["Events"],"summary":"GET /api/events","description":"Returns all events in the log.","operationId":"get_events","responses":{"200":{"description":"Events retrieved","content":{"application/json":{"schema":{"$ref":"#/components/schemas/EventsResponse"}}}}}}},"/api/state":{"get":{"tags":["State"],"summary":"GET /api/state","description":"Returns the current marking and enabled transitions.","operationId":"get_state","responses":{"200":{"description":"State retrieved","content":{"application/json":{"schema":{"$ref":"#/components/schemas/StateResponse"}}}}}}},"/api/topology":{"get":{"tags":["Topology"],"summary":"GET /api/topology","description":"Returns the Petri Net topology.","operationId":"get_topology","responses":{"200":{"description":"Topology retrieved","content":{"application/json":{"schema":{"$ref":"#/components/schemas/TopologyResponse"}}}}}}}},"components":{"schemas":{"Arc":{"type":"object","description":"An arc connecting a place and a transition in the Petri Net.\nArcs define the flow of tokens during transition firing.","required":["id","place_id","transition_id","direction"],"properties":{"direction":{"$ref":"#/components/schemas/ArcDirection"},"id":{"$ref":"#/components/schemas/ArcId"},"place_id":{"$ref":"#/components/schemas/PlaceId"},"transition_id":{"$ref":"#/components/schemas/TransitionId"},"weight":{"type":"integer","description":"Number of tokens consumed/produced (default: 1)","minimum":0}}},"ArcDirection":{"type":"string","description":"Direction of an arc in the Petri Net.","enum":["place_to_transition","transition_to_place"]},"ArcId":{"type":"string","format":"uuid"},"CommandResponse":{"type":"object","description":"Generic command response","required":["success"],"properties":{"error":{"type":"string","nullable":true},"event":{"allOf":[{"$ref":"#/components/schemas/PersistedEvent"}],"nullable":true},"success":{"type":"boolean"}}},"CreateTokenRequest":{"type":"object","description":"Request for POST /api/command/create-token","required":["place_id","color"],"properties":{"color":{"$ref":"#/components/schemas/TokenColor"},"place_id":{"$ref":"#/components/schemas/PlaceId"}}},"DomainEvent":{"oneOf":[{"type":"object","description":"The Petri Net topology was initialized","required":["net","type"],"properties":{"net":{"$ref":"#/components/schemas/PetriNet"},"type":{"type":"string","enum":["NetInitialized"]}}},{"type":"object","description":"A new token was created and placed","required":["token","place_id","type"],"properties":{"place_id":{"$ref":"#/components/schemas/PlaceId"},"token":{"$ref":"#/components/schemas/Token"},"type":{"type":"string","enum":["TokenCreated"]}}},{"type":"object","description":"A transition was fired, consuming and producing tokens","required":["transition_id","consumed_tokens","produced_tokens","type"],"properties":{"consumed_tokens":{"type":"array","items":{"type":"array","items":{"allOf":[{"$ref":"#/components/schemas/PlaceId"},{"$ref":"#/components/schemas/TokenId"}]}},"description":"Tokens consumed from input places: (place_id, token_id)"},"produced_tokens":{"type":"array","items":{"type":"array","items":{"allOf":[{"$ref":"#/components/schemas/PlaceId"},{"$ref":"#/components/schemas/Token"}]}},"description":"Tokens produced in output places: (place_id, token)"},"transition_id":{"$ref":"#/components/schemas/TransitionId"},"type":{"type":"string","enum":["TransitionFired"]}}},{"type":"object","description":"A token was consumed (removed from the net entirely)","required":["token_id","place_id","type"],"properties":{"place_id":{"$ref":"#/components/schemas/PlaceId"},"token_id":{"$ref":"#/components/schemas/TokenId"},"type":{"type":"string","enum":["TokenConsumed"]}}},{"type":"object","description":"An error occurred during execution","required":["message","type"],"properties":{"message":{"type":"string"},"type":{"type":"string","enum":["ErrorOccurred"]}}}],"description":"Domain events representing all possible state changes in the Petri Net.\nThese are the \"facts\" that get recorded in the event log.","discriminator":{"propertyName":"type"}},"ErrorResponse":{"type":"object","description":"Error response","required":["error"],"properties":{"error":{"type":"string"}}},"EventsResponse":{"type":"object","description":"Response for GET /api/events","required":["events","chain_valid"],"properties":{"chain_valid":{"type":"boolean"},"events":{"type":"array","items":{"$ref":"#/components/schemas/PersistedEvent"}}}},"Guard":{"oneOf":[{"type":"object","required":["type"],"properties":{"type":{"type":"string","enum":["Always"]}}},{"type":"object","required":["type","value"],"properties":{"type":{"type":"string","enum":["ColorEquals"]},"value":{"$ref":"#/components/schemas/TokenColor"}}},{"type":"object","required":["type","value"],"properties":{"type":{"type":"string","enum":["IntegerGreaterThan"]},"value":{"type":"integer","format":"int64","description":"Integer token must be greater than this value"}}},{"type":"object","required":["type","value"],"properties":{"type":{"type":"string","enum":["IntegerLessThan"]},"value":{"type":"integer","format":"int64","description":"Integer token must be less than this value"}}},{"type":"object","required":["type","value"],"properties":{"type":{"type":"string","enum":["DataHasField"]},"value":{"type":"string","description":"Data token must have this field"}}}],"description":"A guard condition that must be satisfied for a transition to fire.\nGuards are evaluated against the tokens in input places.","discriminator":{"propertyName":"type"}},"Marking":{"type":"object","description":"The current distribution of tokens across places.\nThis is the dynamic state of the Petri Net.","required":["tokens"],"properties":{"tokens":{"type":"object","description":"Map from place ID to tokens at that place","additionalProperties":{"type":"array","items":{"$ref":"#/components/schemas/Token"}}}}},"PersistedEvent":{"type":"object","description":"A persisted event with metadata and hash chaining for audit trail.","required":["sequence","timestamp","event","hash"],"properties":{"event":{"$ref":"#/components/schemas/DomainEvent"},"hash":{"type":"string","description":"SHA-256 hash of this event's content"},"previous_hash":{"type":"string","description":"Hash of the previous event (None for first event)","nullable":true},"sequence":{"type":"integer","format":"int64","description":"Sequential event number (monotonically increasing)","minimum":0},"timestamp":{"type":"string","format":"date-time","description":"When this event was recorded"}}},"PetriNet":{"type":"object","description":"The complete Petri Net topology (structure).\nThis is the \"board\" on which the token game is played.","required":["places","transitions","arcs"],"properties":{"arcs":{"type":"array","items":{"$ref":"#/components/schemas/Arc"},"description":"All arcs connecting places and transitions"},"places":{"type":"array","items":{"$ref":"#/components/schemas/Place"},"description":"All places in the net"},"transitions":{"type":"array","items":{"$ref":"#/components/schemas/Transition"},"description":"All transitions in the net"}}},"Place":{"type":"object","description":"A place (location) in the Petri Net where tokens can reside.","required":["id","name","place_type"],"properties":{"capacity":{"type":"integer","description":"Maximum number of tokens allowed (None = unlimited)","nullable":true,"minimum":0},"id":{"$ref":"#/components/schemas/PlaceId"},"name":{"type":"string","description":"Human-readable name"},"place_type":{"$ref":"#/components/schemas/PlaceType"}}},"PlaceId":{"type":"string","format":"uuid"},"PlaceType":{"type":"string","description":"The semantic type of a place in the Petri Net.\nHelps the UI and analysis tools understand the role of each place.","enum":["state","resource","signal"]},"StateResponse":{"type":"object","description":"Response for GET /api/state","required":["marking","enabled_transitions"],"properties":{"enabled_transitions":{"type":"array","items":{"$ref":"#/components/schemas/TransitionId"}},"marking":{"$ref":"#/components/schemas/Marking"}}},"Token":{"type":"object","description":"A token in the Petri Net.\nTokens are immutable - they are created and consumed, never modified.","required":["id","color","created_at"],"properties":{"color":{"$ref":"#/components/schemas/TokenColor"},"created_at":{"type":"string","format":"date-time","description":"When this token was created"},"created_by_event":{"type":"integer","format":"int64","description":"The event sequence number that created this token (for provenance)","nullable":true,"minimum":0},"id":{"$ref":"#/components/schemas/TokenId"}}},"TokenColor":{"oneOf":[{"type":"object","required":["type"],"properties":{"type":{"type":"string","enum":["Unit"]}}},{"type":"object","required":["type","value"],"properties":{"type":{"type":"string","enum":["Integer"]},"value":{"type":"integer","format":"int64","description":"A numeric value (fungible resource)"}}},{"type":"object","required":["type","value"],"properties":{"type":{"type":"string","enum":["Data"]},"value":{"description":"Structured JSON data (non-fungible, complex state)"}}}],"description":"The \"color\" of a token in Colored Petri Net terminology.\nRepresents the data carried by a token.","discriminator":{"propertyName":"type"}},"TokenId":{"type":"string","format":"uuid"},"TopologyResponse":{"type":"object","description":"Response for GET /api/topology","properties":{"topology":{"allOf":[{"$ref":"#/components/schemas/PetriNet"}],"nullable":true}}},"Transition":{"type":"object","description":"A transition (action) in the Petri Net that consumes tokens from input\nplaces and produces tokens in output places.","required":["id","name"],"properties":{"guard":{"$ref":"#/components/schemas/Guard"},"id":{"$ref":"#/components/schemas/TransitionId"},"name":{"type":"string","description":"Human-readable name"}}},"TransitionId":{"type":"string","format":"uuid"}}},"tags":[{"name":"Topology","description":"Petri Net structure endpoints"},{"name":"Events","description":"Event log endpoints"},{"name":"State","description":"Current state endpoints"},{"name":"Commands","description":"Command endpoints for mutations"}]}