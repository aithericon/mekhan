SCHEDULER_BACKEND=slurm
SCHEDULER_SIGNAL_ROUTES=running:sig_running,completed:sig_completed,failed:sig_failed,timed_out:sig_timed_out
SLURM_SSH_HOST=localhost
SLURM_SSH_PORT=2222
SLURM_SSH_USER=testuser
SLURM_SSH_KEY=infra/slurm/ssh/slurm_test
SLURM_SSH_KNOWN_HOSTS=accept
SLURM_POLL_INTERVAL_SECS=2
SLURM_TEMPLATE_DIR=/opt/petri/templates
NATS_URL=nats://localhost:4333
