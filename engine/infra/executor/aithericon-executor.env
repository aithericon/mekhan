# --- Aithericon executor service settings ---
# Must match EXECUTOR_NAMESPACE from executor.env so jobs land in the right queue.
EXECUTOR_NATS_URL=nats://localhost:4333
EXECUTOR_NAMESPACE=executor_jobs
EXECUTOR_NAME=demo-executor
EXECUTOR_BASE_DIR=/tmp/aithericon-executor-demo
EXECUTOR_CONCURRENCY=4
EXECUTOR_DEFAULT_TIMEOUT_SECS=60
EXECUTOR_SOURCE=nats_queue
EXECUTOR_LIFETIME=daemon
