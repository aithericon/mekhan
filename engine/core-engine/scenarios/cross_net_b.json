{
  "name": "Cross-Net Consumer (Net B)",
  "places": [
    {
      "id": "inbox",
      "name": "Inbox (bridge-in)",
      "type": "state",
      "initial_tokens": []
    },
    {
      "id": "processed",
      "name": "Processed",
      "type": "state",
      "initial_tokens": []
    },
    {
      "id": "reply_outbox",
      "name": "Reply Outbox",
