# =============================================================================
# deploy/dev/.secrets — local plaintext secret overrides (gitignored)
# =============================================================================
# Copy to `.secrets` and fill in. Sourced by .envrc AFTER ../secrets.sh, so an
# export here WINS over the rbw lookup. The .envrc resolves everything else from
# Vault, so the ONLY thing you normally need here is the cluster Vault token.
#
#   cp .secrets.example .secrets    # then `direnv allow`
#
# (If you keep the token in rbw under clusters/aithericon-dev → vault-root-token,
#  you don't need this file at all.)

# Cluster Vault token (shared HetznerCluster bootstrap token).
export VAULT_TOKEN="hvs.REPLACE_ME"

# Optional: pin a Nomad ACL token instead of letting .envrc read it from Vault.
# export NOMAD_TOKEN="REPLACE_ME"
