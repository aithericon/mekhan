# Copy to dev.auto.tfvars (gitignored).
#
# NAMING NOTE: this is mekhan's *dev* environment, but it deploys to the
# *prod* HetznerCluster (the only cluster that exists). Different scope:
# we just run as a separate Nomad job (`mekhan-service`) with its own
# hostname so it doesn't collide with a future mekhan-prod deploy.

# ── Nomad target — the prod cluster (10.20.x subnet) ────────────────────────
nomad_address     = "https://10.20.0.10:4646"
nomad_region      = "global"
nomad_namespace   = "default"
nomad_datacenters = ["dc1"]
node_class        = "stateless"

# ── Image ───────────────────────────────────────────────────────────────────
image_repository = "forge.aithericon.eu/milanender/mekhan-service"

# ── External exposure ───────────────────────────────────────────────────────
# Distinct hostname so a future mekhan-prod can claim mekhan.aithericon.eu
# without conflict.
hostname        = "mekhan.dev.aithericon.eu"
traefik_enabled = true

# ── Runtime endpoints (resolved via Consul DNS on the cluster) ──────────────
# These addresses are seen by Nomad allocations — not by your local machine.
# (mekhan's Postgres host is set by postgres_runtime_host in variables.tf;
# its default `postgres-primary.service.consul` is correct.)
nats_url      = "nats://nats.service.consul:4222"
petri_lab_url = "http://engine.service.consul:3030"

# Hetzner Object Storage (same provider as the tfstate bucket).
s3_endpoint = "https://fsn1.your-objectstorage.com"
s3_bucket   = "mekhan-artifacts-dev"

# ── Auth & logging ──────────────────────────────────────────────────────────
auth_mode = "dev_noop"
rust_log  = "info,mekhan_service=debug"

# ── Resources ───────────────────────────────────────────────────────────────
cpu_mhz   = 500
memory_mb = 512
