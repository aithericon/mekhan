# Copy to dev.auto.tfvars (gitignored).
#
# This is the *dev* environment. It runs on the SAME HetznerCluster as prod
# (deploy/prod) but is fully isolated: distinct Nomad job (mekhan-service-dev),
# Consul services, Traefik router, Postgres DB (mekhan_dev), NATS account
# (mekhan-dev), S3 bucket, Vault role, and Zitadel org. All of that divergence
# flows from `environment` below via locals.tf — the *.tf files are identical
# to deploy/prod's.

# ── Environment ──────────────────────────────────────────────────────────────
environment = "dev"

# ── Nomad target — the shared cluster (10.20.x subnet) ──────────────────────
nomad_address     = "https://10.20.0.10:4646"
nomad_region      = "global"
nomad_namespace   = "default"
nomad_datacenters = ["dc1"]
node_class        = "stateless"

# ── Image ───────────────────────────────────────────────────────────────────
image_repository = "zot.service.consul:5000/milanender/mekhan-service"

# ── External exposure ───────────────────────────────────────────────────────
# dev lives on the subdomain; prod (deploy/prod) owns the canonical
# mekhan.aithericon.eu. Distinct hostnames + Traefik routers = no collision.
hostname        = "mekhan.dev.aithericon.eu"
traefik_enabled = true

# ── Runtime endpoints (resolved via Consul DNS on the cluster) ──────────────
# These addresses are seen by Nomad allocations — not by your local machine.
# (mekhan's Postgres host is set by postgres_runtime_host in variables.tf;
# its default `postgres-primary.service.consul` is correct.)
# petri_lab_url is intentionally NOT set — it derives from the env-suffixed
# engine Consul service (engine-dev.service.consul:<engine_service_port>) in
# locals.tf. Set it only to point at an out-of-band engine.
nats_url = "nats://nats.service.consul:4222"

# Vault — VaultResourceStore (mekhan), {{secret:...}} wrap (engine), and
# wrapping-token unwrap (executor) all reach this address. Default already
# matches the cluster's internal Vault, so override only if testing against
# a different server.
# vault_addr  = "http://10.20.0.20:8200"

# Hetzner Object Storage (same provider as the tfstate bucket).
s3_endpoint = "https://fsn1.your-objectstorage.com"
s3_bucket   = "mekhan-artifacts-dev"

# ── Auth & logging ──────────────────────────────────────────────────────────
auth_mode = "bff"
rust_log  = "info,mekhan_service=debug"

# Platform admins (REQUIRED in bff mode). OIDC subjects/emails granted
# is_platform_admin — needed to mint the shared worker pool's registration token
# (the executor enrolls into the platform `default` pool). Without one, worker
# enroll fails with "worker group 'default' does not resolve …".
platform_admins = ["ops@aithericon.com"]

# Dedicated Zitadel org for this env (the isolation boundary for users/apps).
# prod uses a different org name so a dev login can't reach prod.
zitadel_org_name = "Mekhan Testers"

# ── Invite email ──────────────────────────────────────────────────────────────
# mode=smtp makes the in-app invite feature send the accept link by email.
# Non-secret settings here; the SMTP username/password are secrets and must be
# injected in CI via TF_VAR_email_smtp_username / TF_VAR_email_smtp_password
# (sourced from Vault), NOT committed.
email_mode         = "smtp"
email_from_address = "id@aithericon.eu"
email_smtp_host    = "mail.your-server.de"
email_smtp_port    = 587

# Terraform creates ONLY the bootstrap admin here. Every other tester is
# onboarded from INSIDE Mekhan (the admin sends in-app invites) — no TF entry
# needed. The admin exists in TF solely so it can be seeded as workspace owner.
# On apply it gets a random initial password published to Vault; read it with:
#   vault kv get -field=initial_password secret/services/mekhan/dev/testers/mekhan_admin
tester_users = {
  mekhan_admin = {
    username   = "mekhan-admin"
    first_name = "Mekhan"
    last_name  = "Admin"
    email = "mekhan-admin@aithericon.eu"
    role  = "mekhan_admin"
  }
}

# Seed mekhan_admin as OWNER of the Testers Mekhan workspace (one-time bootstrap).
# After the first deploy, run `tofu output -raw testers_workspace_bootstrap_sql`
# and execute it once against the mekhan_dev DB. Then all onboarding is in-app.
workspace_owner_user_key = "mekhan_admin"

# ── Resources ───────────────────────────────────────────────────────────────
cpu_mhz   = 500
memory_mb = 512
