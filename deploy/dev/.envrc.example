# =============================================================================
# deploy/dev/.envrc — local deploy environment (direnv)
# =============================================================================
# Copy to `.envrc` (gitignored), fill in real values, then run:
#     direnv allow
# from this directory. Every `tofu` / `just ci::deploy-dev` invocation will
# then have these vars in its environment.
#
# Reference: HetznerCluster/environments/prod/.secrets — most values can be
# copy-pasted from there (Hetzner S3 keypair, encryption passphrase, registry
# password). The Nomad token + Postgres URL are mekhan-specific and have to
# be provisioned on the cluster side first (see deploy/README.md § A).
# =============================================================================

# ── Hetzner Object Storage (for tfstate backend) ─────────────────────────────
# From HetznerCluster/environments/prod/.secrets:
#   TF_VAR_hetzner_s3_access_key / TF_VAR_hetzner_s3_secret_key
export AWS_ACCESS_KEY_ID="REPLACE_ME"
export AWS_SECRET_ACCESS_KEY="REPLACE_ME"

# ── tfstate encryption passphrase ────────────────────────────────────────────
# Reuse the same passphrase the rest of the cluster uses (in .secrets) so
# you don't end up with two different keys for state in the same bucket.
export TF_VAR_state_encryption_passphrase="REPLACE_ME"

# ── mekhan-service artifact bucket creds ─────────────────────────────────────
# Same Hetzner Object Storage account, distinct bucket (mekhan-artifacts-dev).
# Easiest: reuse the same keypair as AWS_* above. Issue a scoped keypair
# later if/when you want least-privilege.
export TF_VAR_s3_access_key="REPLACE_ME"
export TF_VAR_s3_secret_key="REPLACE_ME"

# ── Forgejo registry (image pull on Nomad clients) ───────────────────────────
# Username is non-secret (in HetznerCluster env.hcl). Password is the
# `TF_VAR_docker_registry_password` field of .secrets.
export TF_VAR_registry_user="MilanEnder"
export TF_VAR_registry_password="REPLACE_ME"

# ── Nomad ACL token (NOT in cluster .secrets — mint it) ──────────────────────
# On a machine that already has a Nomad management token (you, probably,
# as cluster admin):
#     nomad acl policy apply -description="mekhan dev deploy" mekhan-dev-deploy <<'HCL'
#     namespace "default" {
#       policy = "write"
#       capabilities = ["submit-job","read-job","list-jobs","dispatch-job"]
#     }
#     HCL
#     nomad acl token create -name="mekhan-dev" -type=client -policy=mekhan-dev-deploy
# Paste the SecretID it prints below.
export TF_VAR_nomad_token="REPLACE_ME"

# ── Patroni superuser password (one-time fetch from Vault) ───────────────────
# This is the ONLY cluster credential mekhan's deploy needs. The postgresql
# provider in providers.tf uses it to CREATE ROLE / CREATE DATABASE for
# mekhan_dev; once mekhan is provisioned, the Nomad allocation talks to
# Postgres as `mekhan_dev`, not as superuser.
#
# Fetch once:
#     export VAULT_ADDR=http://10.20.0.20:8200
#     export VAULT_TOKEN=<your hvs.… token from HetznerCluster/.../.secrets>
#     vault kv get -field=superuser_password secret/postgres/patroni
#
# Paste the result:
export TF_VAR_postgres_admin_password="REPLACE_ME"

# NOTE: TF_VAR_database_url no longer exists. The URL is computed at apply
# time from random_password.mekhan_dev + the Postgres host vars, and lives
# in the encrypted tfstate. `tofu output -raw database_url` to see it.

# ── Nomad CLI convenience (used by `just ci::verify-deploy dev`) ─────────────
# Also picked up by the Terraform `nomad` provider. NOMAD_SKIP_VERIFY=true
# bypasses TLS cert verification — the cluster's Nomad API is signed by an
# internal CA we don't trust on operator machines.
export NOMAD_ADDR="https://10.20.0.10:4646"
export NOMAD_TOKEN="$TF_VAR_nomad_token"
export NOMAD_SKIP_VERIFY="true"
