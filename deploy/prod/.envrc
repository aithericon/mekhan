# =============================================================================
# .envrc — prod deploy environment for mekhan (TRACKED)
# =============================================================================
# Non-secret cluster config lives here. The Vault token comes from rbw via
# ../secrets.sh (or deploy/prod/.secrets, gitignored); EVERYTHING ELSE is resolved
# straight FROM Vault below — the same lookups .woodpecker/41-deploy-prod.yml runs
# — so a developer only needs the Vault token to run `tofu` / `just ci::deploy-prod`
# locally with the same environment CI has. Run `direnv allow` after editing.
#
# Reachability: 10.20.0.* + *.service.consul resolve only inside the cluster
# network (NetBird). Off-mesh, the Vault lookups no-op and the vars stay empty.

dotenv_if_exists .env

if [[ -d .cargo/bin ]]; then
  PATH_add "$(pwd)/.cargo/bin"
fi

# ── Cluster endpoints (shared HetznerCluster — identical for dev + prod) ──────
# From an operator box on the NetBird mesh, cluster services resolve as
# `<svc>.service.consul.aithericon` (the in-cluster suffix is just `.consul`;
# `.aithericon` is the split-DNS zone NetBird hands out). Vault is HA across 3
# nodes — the service name follows redirects to the active one. Nomad isn't
# registered under that name here, so it stays on its node IP.
export VAULT_ADDR="http://vault.service.consul.aithericon:8200"
export NOMAD_ADDR="https://10.20.0.10:4646"
export NOMAD_SKIP_VERIFY="true"

# ── Bootstrap secret (Vault token): rbw loader + optional local override ──────
# secrets.sh (committed, rbw lookup) first, then .secrets (gitignored plaintext)
# so a local export wins, then an optional .envrc.local.
ENV_DIR="$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")" && pwd)"
export ENV_NAME="prod"
source "${ENV_DIR}/../secrets.sh"
[ -f "${ENV_DIR}/.secrets" ] && source "${ENV_DIR}/.secrets"
[ -f "${ENV_DIR}/.envrc.local" ] && source_env "${ENV_DIR}/.envrc.local"

# ── Everything else resolved FROM Vault (mirrors .woodpecker/41-deploy-prod.yml) ─
# Graceful: with no/invalid VAULT_TOKEN these no-op, leaving vars empty so a
# later `tofu apply` fails loudly rather than deploying half-configured.
if command -v vault >/dev/null 2>&1 && [[ -n "${VAULT_TOKEN:-}" ]]; then
  _vget() { vault kv get -field="$2" "$1" 2>/dev/null || true; }

  # Nomad ACL token
  if [[ -z "${NOMAD_TOKEN:-}" ]]; then export NOMAD_TOKEN="$(_vget secret/nomad/bootstrap token)"; fi
  export TF_VAR_nomad_token="${NOMAD_TOKEN:-}"

  # Postgres superuser (Patroni) — admin password + in-cluster host
  export TF_VAR_postgres_admin_password="$(_vget secret/postgres/patroni superuser_password)"
  export TF_VAR_postgres_admin_host="postgres-primary.service.consul"

  # Forgejo registry (image pull on the Nomad clients)
  export TF_VAR_registry_user="$(_vget secret/docker/registry username)"
  export TF_VAR_registry_password="$(_vget secret/docker/registry token)"

  # Hetzner S3 — used BOTH for the tfstate backend (AWS_*) and the mekhan
  # artifact bucket (TF_VAR_s3_*). Same key, per .woodpecker/41-deploy-prod.yml.
  export AWS_ACCESS_KEY_ID="$(_vget secret/services/mekhan/prod hetzner_s3_access_key)"
  export AWS_SECRET_ACCESS_KEY="$(_vget secret/services/mekhan/prod hetzner_s3_secret_key)"
  export TF_VAR_s3_access_key="${AWS_ACCESS_KEY_ID}"
  export TF_VAR_s3_secret_key="${AWS_SECRET_ACCESS_KEY}"

  # tfstate encryption + SMTP relay creds + Zitadel org id
  export TF_VAR_state_encryption_passphrase="$(_vget secret/services/mekhan/prod state_encryption_passphrase)"
  export TF_VAR_email_smtp_username="$(_vget secret/services/mekhan/prod smtp_username)"
  export TF_VAR_email_smtp_password="$(_vget secret/services/mekhan/prod smtp_password)"
  export TF_VAR_zitadel_org_id="$(_vget secret/services/mekhan/prod org_id)"

  # Zitadel IaC JWT — the provider opens this PATH (not the contents). Write the
  # key to a stable file under the direnv layout dir and point the var at it.
  _zjwt="$(_vget secret/zitadel/iac-jwt key)"
  if [[ -n "${_zjwt}" ]]; then
    _zjwt_file="$(direnv_layout_dir)/zitadel-iac-jwt.json"
    mkdir -p "$(direnv_layout_dir)"
    printf '%s' "${_zjwt}" > "${_zjwt_file}"
    chmod 600 "${_zjwt_file}"
    export TF_VAR_zitadel_jwt_file="${_zjwt_file}"
    unset _zjwt_file
  fi
  unset _zjwt
  unset -f _vget
fi

# ── prodpsql: psql into the cluster's mekhan_prod DB (Patroni superuser) ──────
# Operator-facing host uses the `.consul.aithericon` split-DNS name (the in-cluster
# `.consul` form — what the deployed service uses, TF_VAR_postgres_admin_host —
# doesn't resolve off-cluster). direnv can't export functions, so drop a wrapper
# into the layout bin + PATH_add.
if [[ -n "${TF_VAR_postgres_admin_password:-}" ]]; then
  export MEKHAN_DSN="postgres://postgres:${TF_VAR_postgres_admin_password}@postgres-primary.service.consul.aithericon:5432/mekhan_prod"
fi
_bin="$(direnv_layout_dir)/bin"
mkdir -p "${_bin}"
cat > "${_bin}/prodpsql" <<'PSQL'
#!/usr/bin/env bash
set -euo pipefail
if [[ -z "${MEKHAN_DSN:-}" ]]; then
  echo "prodpsql: MEKHAN_DSN unset (vault locked/unreachable, or not in deploy/prod)" >&2
  exit 1
fi
exec psql "${MEKHAN_DSN}" "$@"
PSQL
chmod +x "${_bin}/prodpsql"
PATH_add "${_bin}"
unset _bin
