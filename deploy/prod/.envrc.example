# =============================================================================
# deploy/prod/.envrc — local prod deploy environment (direnv)
# =============================================================================
# Copy to `.envrc` (gitignored), fill in real values, then `direnv allow` from
# this directory. Every `tofu` / `just ci::deploy-prod` invocation will then
# have these vars in its environment.
#
# prod runs on the SAME HetznerCluster as dev but with FULLY SEPARATE secrets:
# a distinct Nomad token, a distinct artifact bucket key, and a distinct Vault
# path (secret/services/mekhan/prod). Do not reuse dev's credentials here.
# =============================================================================

# ── Hetzner Object Storage (for tfstate backend) ─────────────────────────────
# Same tfstate bucket as dev (tfstate-aithericon-prod) — the state KEY differs
# (mekhan/prod/...), set in backend.tf. From HetznerCluster .secrets.
export AWS_ACCESS_KEY_ID="REPLACE_ME"
export AWS_SECRET_ACCESS_KEY="REPLACE_ME"

# ── tfstate encryption passphrase ────────────────────────────────────────────
# Reuse the cluster-wide passphrase so all state in the bucket uses one key.
export TF_VAR_state_encryption_passphrase="REPLACE_ME"

# ── mekhan-service prod artifact bucket creds (bucket: mekhan-artifacts) ──────
export TF_VAR_s3_access_key="REPLACE_ME"
export TF_VAR_s3_secret_key="REPLACE_ME"

# ── Forgejo registry (image pull on Nomad clients) ───────────────────────────
export TF_VAR_registry_user="MilanEnder"
export TF_VAR_registry_password="REPLACE_ME"

# ── Nomad ACL token — mint a PROD-scoped one (distinct from dev) ──────────────
#     nomad acl policy apply -description="mekhan prod deploy" mekhan-prod-deploy <<'HCL'
#     namespace "default" {
#       policy = "write"
#       capabilities = ["submit-job","read-job","list-jobs","dispatch-job"]
#     }
#     HCL
#     nomad acl token create -name="mekhan-prod" -type=client -policy=mekhan-prod-deploy
export TF_VAR_nomad_token="REPLACE_ME"

# ── Postgres superuser (provision the mekhan_prod DB/role on Patroni) ─────────
#     vault kv get -field=superuser_password secret/postgres/patroni
export TF_VAR_postgres_admin_password="REPLACE_ME"

# ── Zitadel IaC JWT (provision the prod "Mekhan" org/apps) ────────────────────
#     vault kv get -field=key secret/zitadel/iac-jwt > /tmp/zitadel-iac-jwt-prod.json
export TF_VAR_zitadel_jwt_file="/tmp/zitadel-iac-jwt-prod.json"

# ── Invite-email relay creds (email_mode=smtp) ───────────────────────────────
#     vault kv get -field=smtp_username secret/services/mekhan/prod
export TF_VAR_email_smtp_username="REPLACE_ME"
export TF_VAR_email_smtp_password="REPLACE_ME"

# ── Nomad / Vault CLI (verify-deploy + NATS bootstrap) ───────────────────────
export NOMAD_ADDR="https://10.20.0.10:4646"
export NOMAD_TOKEN="$TF_VAR_nomad_token"
export NOMAD_SKIP_VERIFY="true"

export VAULT_ADDR="http://10.20.0.20:8200"
export VAULT_TOKEN="REPLACE_ME"
