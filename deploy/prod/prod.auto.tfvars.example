# Copy to prod.auto.tfvars (gitignored).
#
# This is the *prod* environment. It runs on the SAME HetznerCluster as dev
# (deploy/dev) but is fully isolated: distinct Nomad job (mekhan-service-prod),
# Consul services, Traefik router, Postgres DB (mekhan_prod), NATS account
# (mekhan-prod), S3 bucket, Vault role, and Zitadel org. All of that divergence
# flows from `environment` below via locals.tf — the *.tf files are identical
# to deploy/dev's (only backend.tf's state key differs).

# ── Environment ──────────────────────────────────────────────────────────────
environment = "prod"

# ── Nomad target — the shared cluster (10.20.x subnet) ──────────────────────
nomad_address     = "https://10.20.0.10:4646"
nomad_region      = "global"
nomad_namespace   = "default"
nomad_datacenters = ["dc1"]
node_class        = "stateless"

# ── Image ───────────────────────────────────────────────────────────────────
image_repository = "zot.service.consul:5000/milanender/mekhan-service"

# ── External exposure ───────────────────────────────────────────────────────
# prod owns the canonical hostname; dev lives on mekhan.dev.aithericon.eu.
hostname        = "mekhan.aithericon.eu"
traefik_enabled = true

# ── Ports ─────────────────────────────────────────────────────────────────────
# DISTINCT from dev's defaults (3100 / 3030). The jobs use STATIC host ports, so
# if dev and prod land on the same stateless node they'd collide — keep these
# non-overlapping. (Running >1 replica also needs these to become dynamic; the
# job is count=1 today.)
service_port        = 3200
engine_service_port = 3130

# ── Runtime endpoints (resolved via Consul DNS on the cluster) ──────────────
# petri_lab_url is intentionally NOT set — it derives from the env-suffixed
# engine Consul service (engine-prod.service.consul:3130) in locals.tf.
nats_url = "nats://nats.service.consul:4222"

# Hetzner Object Storage. prod gets the canonical (un-suffixed) artifact bucket.
s3_endpoint = "https://fsn1.your-objectstorage.com"
s3_bucket   = "mekhan-artifacts"

# ── Auth & logging ──────────────────────────────────────────────────────────
auth_mode = "bff"
rust_log  = "info"

# Platform admins (REQUIRED in bff mode). OIDC subjects/emails granted
# is_platform_admin — needed to mint the shared worker pool's registration token
# (the executor enrolls into the platform `default` pool). Without one, worker
# enroll fails with "worker group 'default' does not resolve …".
platform_admins = ["ops@aithericon.com"]

# Dedicated Zitadel org for prod (the isolation boundary for users/apps).
zitadel_org_name = "Mekhan"

# ── Invite email ──────────────────────────────────────────────────────────────
# Same relay as dev; username/password are secrets injected in CI via
# TF_VAR_email_smtp_username / TF_VAR_email_smtp_password (from Vault).
email_mode         = "smtp"
email_from_address = "id@aithericon.eu"
email_smtp_host    = "mail.your-server.de"
email_smtp_port    = 587

# Bootstrap admin for prod's "Testers" workspace (one-time). Random initial
# password published to Vault at secret/services/mekhan/prod/testers/mekhan_admin.
# All other onboarding is in-app via invites.
# NOTE: username + email must be globally UNIQUE across envs — Zitadel enforces
# instance-wide uniqueness, and dev already owns mekhan-admin@aithericon.eu.
tester_users = {
  mekhan_admin = {
    username   = "mekhan-admin-prod"
    first_name = "Mekhan"
    last_name  = "Admin"
    email      = "mekhan-admin-prod@aithericon.eu"
    role       = "mekhan_admin"
  }
}
workspace_owner_user_key = "mekhan_admin"

# ── Resources ───────────────────────────────────────────────────────────────
cpu_mhz   = 1000
memory_mb = 1024
