# Caddy in front of Zitadel v4 — the login UI ships as a separate container
# (`zitadel-login`) at /ui/v2/login/*; everything else routes to the core
# zitadel container.
#
# Internal calls from `zitadel-login` to the core also come through here, so
# we force the upstream Host header to `localhost:18080` — Zitadel's instance
# resolver matches the request Host against ExternalDomain and would reject
# `zitadel:8080`.
:8080 {
	handle /ui/v2/login/* {
		reverse_proxy zitadel-login:3000
	}
	handle {
		reverse_proxy zitadel:8080 {
			# Zitadel's instance resolver picks the tenant from Host /
			# X-Forwarded-Host. Internal calls from zitadel-login go through
			# here too, where the original Host is `zitadel-proxy:8080` —
			# pin both to the configured ExternalDomain so resolution works
			# the same for browser + service-to-service traffic.
			header_up Host localhost:18080
			header_up X-Forwarded-Host localhost:18080
			header_up X-Forwarded-Proto http
		}
	}
}
