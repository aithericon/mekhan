          {
            "name": "feed",
            "direction": "in",
            "plane": "data",
            "element": { "type": "binary", "content_type": "text/plain" },
            "transport": "jetstream"
          },
          {
            "name": "shouted",
            "direction": "out",
            "plane": "data",
