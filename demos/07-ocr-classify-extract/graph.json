{
  "nodes": [
    {
      "id": "start",
      "type": "start",
      "position": { "x": 0, "y": 54 },
      "data": {
        "type": "start",
        "label": "Start",
        "processName": "OCR + classify",
        "initial": {
          "id": "in",
          "label": "Document Intake",
          "fields": [
            {
              "name": "document",
              "label": "Document (PDF or image)",
              "kind": "file",
              "required": true,
              "accept": "application/pdf,image/png,image/jpeg"
            }
          ]
        }
      }
    },
    {
      "id": "extract_text",
      "type": "automated_step",
      "position": { "x": 290, "y": 0 },
      "data": {
        "type": "automated_step",
        "label": "Extract text (Kreuzberg)",
        "description": "Borrows the uploaded file from Start via {{ start.document }} — compiler stages it via StoragePath, runner resolves to a local path, Kreuzberg reads it. Outputs are kreuzberg's native ExtractionResult shape 1:1 — `content` (string), `mime_type`, `metadata`, `tables`, `detected_languages`. No renaming or remapping.",
        "executionSpec": {
          "backendType": "kreuzberg",
          "config": {
            "mode": "single",
            "file": "{{ start.document }}",
            "force_ocr": false,
            "ocr": {
              "backend": "tesseract",
              "language": "eng",
              "enable_table_detection": false
            }
          }
        },
        "output": {
          "id": "out",
          "label": "OCR result",
          "fields": [
            {
              "name": "content",
              "label": "Content",
              "kind": "text",
              "required": true
            },
            {
              "name": "mime_type",
              "label": "MIME type",
              "kind": "text",
              "required": false
            },
            {
              "name": "metadata",
              "label": "Metadata",
              "kind": "json",
              "required": false
            },
            {
              "name": "tables",
              "label": "Tables",
              "kind": "json",
              "required": false
            },
            {
              "name": "detected_languages",
              "label": "Detected languages",
              "kind": "json",
              "required": false
            }
          ]
        }
      }
    },
    {
      "id": "classify",
      "type": "agent",
      "position": { "x": 600, "y": 0 },
      "data": {
        "type": "agent",
        "label": "Classify (LLM)",
        "description": "Borrows extract_text.content inline via {{ extract_text.content }} — compiler stages it as a Raw input, runner interpolates it into the prompt at dispatch time. `content` is kreuzberg's native key for the extracted text. Dispatches against the local Ollama daemon (`just dev ollama-up`); model must match the one Ollama has pulled (recipe default qwen3.5:9b — override here AND in `just dev ollama-up`'s OLLAMA_MODEL env var if changed). Qwen3 emits `<think>...</think>` blocks before the JSON answer by default; downstream consumers must tolerate the prefix.",
        "model": {
          "provider": "ollama",
          "model": "qwen3.5:9b",
          "baseUrl": "http://localhost:11434",
          "temperature": 0,
          "maxTokens": 256
        },
        "userPrompt": "Classify this document into one of: invoice, receipt, contract, other.\n\nText:\n---\n{{ extract_text.content }}\n---\n\nReturn JSON: {document_class}.",
        "systemPrompt": "You are a document classifier. Return JSON.",
        "responseFormat": {
          "type": "json_schema",
          "schema": {
            "type": "object",
            "required": [
              "document_class"
            ],
            "properties": {
              "document_class": {
                "type": "string",
                "enum": [
                  "invoice",
                  "receipt",
                  "contract",
                  "other"
                ]
              }
            },
            "additionalProperties": false
          }
        },
        "maxTurns": 1
      }
    },
    {
      "id": "end",
      "type": "end",
      "position": { "x": 930, "y": 44 },
      "data": {
        "type": "end",
        "label": "Done",
        "resultMapping": [
          {
            "targetField": "document_class",
            "expression": "classify.document_class"
          },
          {
            "targetField": "content",
            "expression": "extract_text.content"
          }
        ]
      }
    }
  ],
  "edges": [
    {
      "id": "e_start_extract",
      "source": "start",
      "target": "extract_text",
      "targetHandle": "in",
      "type": "sequence"
    },
    {
      "id": "e_extract_classify",
      "source": "extract_text",
      "target": "classify",
      "targetHandle": "in",
      "type": "sequence"
    },
    {
      "id": "e_classify_end",
      "source": "classify",
      "target": "end",
      "targetHandle": "in",
      "type": "sequence",
      "sourceHandle": "out"
    }
  ]
}
