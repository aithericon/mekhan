{
  "nodes": [
    {
      "id": "start",
      "type": "start",
      "position": { "x": 40, "y": 160 },
      "data": {
        "type": "start",
        "label": "Start",
        "processName": "OCR + classify",
        "initial": {
          "id": "in",
          "label": "Document Intake",
          "fields": [
            {
              "name": "document",
              "label": "Document (PDF or image)",
              "kind": "file",
              "required": true,
              "accept": "application/pdf,image/png,image/jpeg"
            }
          ]
        }
      }
    },
    {
      "id": "extract_text",
      "type": "automated_step",
      "position": { "x": 320, "y": 160 },
      "data": {
        "type": "automated_step",
        "label": "Extract text (Kreuzberg)",
        "description": "Borrows the uploaded file from Start via {{ start.document }} — compiler stages it via StoragePath, runner resolves to a local path, Kreuzberg reads it.",
        "executionSpec": {
          "backendType": "kreuzberg",
          "config": {
            "mode": "single",
            "file": "{{ start.document }}",
            "force_ocr": false,
            "ocr": {
              "backend": "tesseract",
              "language": "eng",
              "enable_table_detection": false
            }
          }
        },
        "output": {
          "id": "out",
          "label": "OCR result",
          "fields": [
            { "name": "full_text",  "label": "Full text", "kind": "text",   "required": true },
            { "name": "page_count", "label": "Pages",     "kind": "number", "required": false }
          ]
        }
      }
    },
    {
      "id": "classify",
      "type": "automated_step",
      "position": { "x": 620, "y": 160 },
      "data": {
        "type": "automated_step",
        "label": "Classify (LLM)",
        "description": "Borrows extract_text.full_text inline via {{ extract_text.full_text }} — compiler stages it as a Raw input, runner interpolates it into the prompt at dispatch time.",
        "executionSpec": {
          "backendType": "llm",
          "config": {
            "provider": "ollama",
            "model": "llama3.2:3b",
            "base_url": "http://localhost:11434",
            "temperature": 0,
            "max_tokens": 256,
            "system_prompt": "You are a document classifier. Return JSON.",
            "prompt": "Classify this document into one of: invoice, receipt, contract, other.\n\nText:\n---\n{{ extract_text.full_text }}\n---\n\nReturn JSON: {document_class}.",
            "response_format": {
              "type": "json_schema",
              "schema": {
                "type": "object",
                "required": ["document_class"],
                "properties": {
                  "document_class": {
                    "type": "string",
                    "enum": ["invoice", "receipt", "contract", "other"]
                  }
                },
                "additionalProperties": false
              }
            }
          }
        },
        "output": {
          "id": "out",
          "label": "Classification",
          "fields": [
            { "name": "document_class", "label": "Class", "kind": "text", "required": true }
          ]
        }
      }
    },
    {
      "id": "end",
      "type": "end",
      "position": { "x": 920, "y": 160 },
      "data": {
        "type": "end",
        "label": "Done",
        "resultMapping": [
          { "targetField": "document_class", "expression": "classify.document_class" },
          { "targetField": "full_text",      "expression": "extract_text.full_text" }
        ]
      }
    }
  ],
  "edges": [
    { "id": "e_start_extract",      "source": "start",        "target": "extract_text", "targetHandle": "in", "type": "sequence" },
    { "id": "e_extract_classify",   "source": "extract_text", "target": "classify",     "targetHandle": "in", "type": "sequence" },
    { "id": "e_classify_end",       "source": "classify",     "target": "end",          "targetHandle": "in", "type": "sequence" }
  ]
}
