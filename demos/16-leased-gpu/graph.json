      "data": {
        "type": "lease_scope",
        "label": "GPU Lease · Nomad",
        "description": "Acquires ONE allocation from the `nomad_dc` datacenter on enter and releases it on exit. Everything inside runs on the held node by CONTAINMENT — the Scheduled body needs no scheduler of its own, it inherits this scope's datacenter. The lease (alloc_id, executor_namespace) is parked write-once so the held drain executor stays warm across every loop iteration. Release happens exactly once at the loop's terminal exit; a held-alloc death fails the run fast.",
        "lease": {
          "pool": "nomad_dc"
        }
      }
    },
    {
      "id": "lp",
      "type": "loop",
      "parentId": "lease",
      "position": { "x": 16, "y": 32 },
      "width": 272,
      "height": 216,
      "data": {
        "type": "loop",
        "label": "Render shots",
        "description": "Renders shots 0..2 on the SAME held GPU. The stop condition is `lp.iteration < 3` (maxIterations is a runaway safety cap, not the bound). Because the alloc is held by the enclosing LeaseScope, each iteration enqueues to the lease's warm drain executor instead of re-queuing a cold job.",
        "maxIterations": 10,
        "loopCondition": "lp.iteration < 3"
      }
    },
    {
      "id": "render",
      "type": "automated_step",
      "parentId": "lp",
      "position": { "x": 16, "y": 32 },
      "data": {
        "type": "automated_step",
        "label": "GPU Render (on lease)",
        "description": "A mock per-shot GPU render. Its deploymentModel is `Scheduled` with NO scheduler — enclosed by the LeaseScope, it lowers to the executor-enqueue path and runs on the held alloc's warm drain executor (not a fresh sbatch/dispatch). Reads the loop counter `lp.iteration` directly to label the shot.",
        "executionSpec": {
          "backendType": "python",
          "entrypoint": "main.py",
          "config": {
            "python": "python3",
            "requirements": [],
            "virtualenv": false,
            "sdk": true,
            "inherit_env": true,
            "env": {}
          }
        },
        "deploymentModel": {
