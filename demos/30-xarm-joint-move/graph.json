{
  "nodes": [
    {
      "id": "start",
      "type": "start",
      "position": { "x": 40, "y": 160 },
      "data": {
        "type": "start",
        "label": "Start",
        "processName": "xArm Joint Move",
        "initial": {
          "id": "in",
          "label": "Begin",
          "fields": []
        }
      }
    },
    {
      "id": "plan",
      "type": "automated_step",
      "slug": "plan",
      "position": { "x": 320, "y": 160 },
      "data": {
        "type": "automated_step",
        "label": "Plan Joint Move",
        "description": "ROS `call_service` to `/xarm_joint_plan` (`xarm_msgs/srv/PlanJoint`). Asks the xArm planner (MoveIt, running in ros2_control fake-hardware mode) to plan a collision-free trajectory to a target joint configuration. The request carries `target` — a SIX-element `float64[]` of joint angles in radians — the first ROS service request the platform authors with an ARRAY field (every turtlesim request was flat scalars). The response is `{ success: bool }`. Runs on an `xarm_fleet` runner that satisfies `ros.robot_model == xarm6`; the rosbridge endpoint is runner-local (`EXECUTOR_ROS__WS_URL`). The embedded `interface_typedefs` (the runner's self-reported catalog entry, merged request+response) let the deriver shape the output port live for this non-bundled robot.",
        "deploymentModel": {
          "mode": "executor",
          "capacity": { "alias": "xarm_fleet" }
        },
        "requirements": {
          "constraints": [
            { "capability": "ros", "field": "robot_model", "op": "eq", "value": "xarm6" }
          ]
        },
        "executionSpec": {
          "backendType": "ros",
          "config": {
            "operation": "call_service",
            "interface_name": "/xarm_joint_plan",
            "interface_type": "xarm_msgs/srv/PlanJoint",
            "fields": { "target": [0.0, -0.3, -0.3, 0.0, 0.6, 0.0] },
            "interface_typedefs": [
              { "type": "xarm_msgs/PlanJoint_Request", "fieldnames": ["target"], "fieldtypes": ["double"], "fieldarraylen": [0] },
              { "type": "xarm_msgs/PlanJoint_Response", "fieldnames": ["success"], "fieldtypes": ["boolean"], "fieldarraylen": [-1] }
            ]
          }
        },
        "output": {
          "id": "out",
          "label": "Output",
          "fields": [
            { "name": "success", "label": "Success", "kind": "bool" }
          ]
        },
        "retryPolicy": { "maxRetries": 0, "backoff": "immediate" }
      }
    },
    {
      "id": "execute",
      "type": "automated_step",
      "slug": "execute",
      "position": { "x": 600, "y": 160 },
      "data": {
        "type": "automated_step",
        "label": "Execute Plan",
        "description": "ROS `call_service` to `/xarm_exec_plan` (`xarm_msgs/srv/PlanExec`). Executes the trajectory the previous step planned, on the (fake) hardware via ros2_control's `xarm6_traj_controller`. Request `{ wait: true }` blocks until the motion completes; response `{ success: bool }`. Same `xarm_fleet` placement + `ros.robot_model == xarm6` Requirement. The plan→exec split mirrors how a real xArm is driven through MoveIt.",
        "deploymentModel": {
          "mode": "executor",
          "capacity": { "alias": "xarm_fleet" }
        },
        "requirements": {
          "constraints": [
            { "capability": "ros", "field": "robot_model", "op": "eq", "value": "xarm6" }
          ]
        },
        "executionSpec": {
          "backendType": "ros",
          "config": {
            "operation": "call_service",
            "interface_name": "/xarm_exec_plan",
            "interface_type": "xarm_msgs/srv/PlanExec",
            "fields": { "wait": true },
            "interface_typedefs": [
              { "type": "xarm_msgs/PlanExec_Request", "fieldnames": ["wait"], "fieldtypes": ["boolean"], "fieldarraylen": [-1] },
              { "type": "xarm_msgs/PlanExec_Response", "fieldnames": ["success"], "fieldtypes": ["boolean"], "fieldarraylen": [-1] }
            ]
          }
        },
        "output": {
          "id": "out",
          "label": "Output",
          "fields": [
            { "name": "success", "label": "Success", "kind": "bool" }
          ]
        },
        "retryPolicy": { "maxRetries": 0, "backoff": "immediate" }
      }
    },
    {
      "id": "read_state",
      "type": "automated_step",
      "slug": "read_state",
      "position": { "x": 880, "y": 160 },
      "data": {
        "type": "automated_step",
        "label": "Read Joint State",
        "description": "ROS `await_topic` on `/joint_states` (`sensor_msgs/msg/JointState`). Blocks for the next joint-state message the broadcaster publishes after the move, capturing where the arm ended up. `await_topic` derives its output port from the message type — JointState's fields land at the TOP LEVEL: `header` (nested), `name` (string[]), `position`/`velocity`/`effort` (float64[]). These ARRAY output fields are the first the platform derives from a live ROS message (the turtle's Pose was all scalars); each maps to a Json port field carrying a JSON-Schema array override the variable picker can descend into. End maps `joint_names = {{ read_state.name }}` and `positions = {{ read_state.position }}` onto the instance result. Same `xarm_fleet` placement + Requirement.",
        "deploymentModel": {
          "mode": "executor",
          "capacity": { "alias": "xarm_fleet" }
        },
        "requirements": {
          "constraints": [
            { "capability": "ros", "field": "robot_model", "op": "eq", "value": "xarm6" }
          ]
        },
        "executionSpec": {
          "backendType": "ros",
          "config": {
            "operation": "await_topic",
            "interface_name": "/joint_states",
            "interface_type": "sensor_msgs/msg/JointState",
            "fields": {},
            "interface_typedefs": [
              { "type": "sensor_msgs/JointState", "fieldnames": ["header", "name", "position", "velocity", "effort"], "fieldtypes": ["std_msgs/Header", "string", "double", "double", "double"], "fieldarraylen": [-1, 0, 0, 0, 0] },
              { "type": "std_msgs/Header", "fieldnames": ["stamp", "frame_id"], "fieldtypes": ["builtin_interfaces/Time", "string"], "fieldarraylen": [-1, -1] },
              { "type": "builtin_interfaces/Time", "fieldnames": ["sec", "nanosec"], "fieldtypes": ["int32", "uint32"], "fieldarraylen": [-1, -1] }
            ]
          }
        },
        "output": {
          "id": "out",
          "label": "Output",
          "fields": [
            { "name": "header", "label": "Header", "kind": "json", "schema": { "type": "object", "properties": { "stamp": {}, "frame_id": { "type": "string" } } } },
            { "name": "name", "label": "Name", "kind": "json", "schema": { "type": "array", "items": { "type": "string" } } },
            { "name": "position", "label": "Position", "kind": "json", "schema": { "type": "array", "items": { "type": ["number", "null"] } } },
            { "name": "velocity", "label": "Velocity", "kind": "json", "schema": { "type": "array", "items": { "type": ["number", "null"] } } },
            { "name": "effort", "label": "Effort", "kind": "json", "schema": { "type": "array", "items": { "type": ["number", "null"] } } }
          ]
        },
        "retryPolicy": { "maxRetries": 0, "backoff": "immediate" }
      }
    },
    {
      "id": "end",
      "type": "end",
      "position": { "x": 1160, "y": 160 },
      "data": {
        "type": "end",
        "label": "Done",
        "resultMapping": [
          { "targetField": "plan_ok", "expression": "plan.success" },
          { "targetField": "exec_ok", "expression": "execute.success" },
          { "targetField": "joint_names", "expression": "read_state.name" },
          { "targetField": "positions", "expression": "read_state.position" }
        ]
      }
    }
  ],
  "edges": [
    { "id": "e_start_plan", "source": "start", "target": "plan", "targetHandle": "in", "type": "sequence" },
    { "id": "e_plan_execute", "source": "plan", "target": "execute", "targetHandle": "in", "type": "sequence" },
    { "id": "e_execute_read", "source": "execute", "target": "read_state", "targetHandle": "in", "type": "sequence" },
    { "id": "e_read_end", "source": "read_state", "target": "end", "targetHandle": "in", "type": "sequence" }
  ]
}
