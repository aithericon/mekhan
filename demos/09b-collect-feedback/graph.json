{
  "nodes": [
    {
      "id": "start",
      "type": "start",
      "position": { "x": 40, "y": 120 },
      "data": {
        "type": "start",
        "label": "Start",
        "processName": "Collect feedback",
        "initial": {
          "id": "in",
          "label": "Form spec",
          "fields": [
            {
              "name": "steps",
              "label": "Form steps",
              "kind": "json",
              "required": true,
              "description": "The form to render, as an array of step objects. Each step: {id, title, blocks:[...]}. A block is either {type:\"mdsvex\", content} for display text or {type:\"input\", field:{name, label, kind, required, options?}} where kind is one of text|textarea|number|select|checkbox|radio|date. `name` is the key the answer comes back under.",
              "schema": {
                "type": "array",
                "title": "TaskStepConfig[]",
                "items": {
                  "type": "object",
                  "required": ["id", "title", "blocks"],
                  "properties": {
                    "id": { "type": "string" },
                    "title": { "type": "string" },
                    "descriptionMdsvex": { "type": "string" },
                    "blocks": {
                      "type": "array",
                      "items": {
                        "oneOf": [
                          {
                            "type": "object",
                            "required": ["type", "content"],
                            "properties": {
                              "type": { "const": "mdsvex" },
                              "content": { "type": "string" }
                            }
                          },
                          {
                            "type": "object",
                            "required": ["type", "field"],
                            "properties": {
                              "type": { "const": "input" },
                              "field": {
                                "type": "object",
                                "required": ["name", "label", "kind"],
                                "properties": {
                                  "name": { "type": "string" },
                                  "label": { "type": "string" },
                                  "kind": {
                                    "type": "string",
                                    "enum": ["text", "textarea", "number", "select", "checkbox", "radio", "date"]
                                  },
                                  "required": { "type": "boolean" },
                                  "options": {
                                    "type": "array",
                                    "items": {
                                      "type": "object",
                                      "required": ["value", "label"],
                                      "properties": {
                                        "value": { "type": "string" },
                                        "label": { "type": "string" }
                                      }
                                    }
                                  }
                                }
                              }
                            }
                          }
                        ]
                      }
                    }
                  }
                }
              }
            }
          ]
        }
      }
    },
    {
      "id": "review",
      "type": "human_task",
      "position": { "x": 340, "y": 120 },
      "data": {
        "type": "human_task",
        "label": "Review",
        "taskTitle": "Agent-requested input",
        "instructionsMdsvex": "The agent designed this form and is waiting on your answers.",
        "stepsRef": "start.steps",
        "steps": []
      }
    },
    {
      "id": "end",
      "type": "end",
      "position": { "x": 640, "y": 120 },
      "data": {
        "type": "end",
        "label": "Answers",
        "resultMapping": [
          { "targetField": "answers", "expression": "review.data" }
        ]
      }
    }
  ],
  "edges": [
    { "id": "e_start_review", "source": "start", "target": "review", "targetHandle": "in", "type": "sequence" },
    { "id": "e_review_end", "source": "review", "target": "end", "targetHandle": "in", "type": "sequence" }
  ]
}
