    { "id": "e_producer_media_validator", "source": "producer", "sourceHandle": "media", "target": "validator", "targetHandle": "media", "type": "sequence" },
    { "id": "e_validator_end", "source": "validator", "target": "end", "targetHandle": "in", "type": "sequence" }
