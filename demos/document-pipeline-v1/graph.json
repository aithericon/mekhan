{
  "nodes": [
    {
      "id": "trigger-intake",
      "type": "trigger",
      "position": { "x": 40, "y": 40 },
      "data": {
        "type": "trigger",
        "label": "Intake API",
        "source": { "kind": "manual", "form": [] },
        "concurrency": "allow",
        "payloadMapping": [
          { "targetField": "document_file", "expression": "document_file" },
          { "targetField": "patient_id",    "expression": "patient_id" }
        ],
        "enabled": true
      }
    },
    {
      "id": "start",
      "type": "start",
      "position": { "x": 40, "y": 220 },
      "data": {
        "type": "start",
        "label": "Start",
        "processName": "Document intake — patient {{ patient_id }}",
        "initial": {
          "id": "in",
          "label": "Document Intake",
          "fields": [
            {
              "name": "document_file",
              "label": "Document (PDF, PNG, JPG)",
              "kind": "file",
              "required": true,
              "accept": "application/pdf,image/png,image/jpeg,image/webp"
            },
            {
              "name": "patient_id",
              "label": "Patient ID",
              "kind": "text",
              "required": true
            }
          ]
        }
      }
    },
    {
      "id": "ocr",
      "type": "automated_step",
      "position": { "x": 280, "y": 220 },
      "data": {
        "type": "automated_step",
        "label": "OCR (kreuzberg)",
        "description": "Extract text + tables + per-page metadata from the uploaded document. Tesseract backend with German+English models and table detection enabled.",
        "executionSpec": {
          "backendType": "kreuzberg",
          "config": {
            "mode": "single",
            "target_file": "{{ start.document_file }}",
            "force_ocr": false,
            "ocr": {
              "backend": "tesseract",
              "language": "deu+eng",
              "enable_table_detection": true
            },
            "pdf": {
              "passwords": []
            }
          }
        },
        "output": {
          "id": "out",
          "label": "OCR result",
          "fields": [
            { "name": "full_text",  "label": "Full text",     "kind": "text",   "required": true },
            { "name": "tables_text","label": "Tables (md)",   "kind": "text",   "required": false },
            { "name": "page_count", "label": "Pages",         "kind": "number", "required": true }
          ]
        }
      }
    },
    {
      "id": "classify",
      "type": "automated_step",
      "position": { "x": 540, "y": 220 },
      "data": {
        "type": "automated_step",
        "label": "Classify (vision LLM)",
        "description": "Vision MoE: looks at the document image and the OCR text together, returns one of the canonical document classes plus a confidence.",
        "executionSpec": {
          "backendType": "llm",
          "config": {
            "provider": "ollama",
            "model": "qwen3.6:35b-a3b",
            "base_url": "http://localhost:11435",
            "temperature": 0,
            "max_tokens": 512,
            "system_prompt": "You are a medical document classification assistant. Look at the document image and the OCR text. Group the page(s) into a single logical document and classify it.",
            "prompt": "Classify this medical document into ONE of: lab_result, prescription, referral_letter, imaging_report, discharge_summary, consultation_note, insurance_form, invoice, consent_form, other.\n\nOCR text (supplementary, truncated to 4000 chars):\n---\n{{ ocr.full_text }}\n---\n\nReturn JSON: {document_class, document_date (YYYY-MM-DD or null), confidence (0..1), reasoning}.",
            "images": [
              {
                "path": "{{ start.document_file }}"
              }
            ],
            "response_format": {
              "type": "json_schema",
              "schema": {
                "type": "object",
                "required": ["document_class", "confidence", "reasoning"],
                "properties": {
                  "document_class": {
                    "type": "string",
                    "enum": [
                      "lab_result", "prescription", "referral_letter",
                      "imaging_report", "discharge_summary", "consultation_note",
                      "insurance_form", "invoice", "consent_form", "other"
                    ]
                  },
                  "document_date": { "type": ["string", "null"] },
                  "confidence":    { "type": "number", "minimum": 0, "maximum": 1 },
                  "reasoning":     { "type": "string" }
                },
                "additionalProperties": false
              }
            }
          }
        },
        "output": {
          "id": "out",
          "label": "Classification",
          "fields": [
            { "name": "document_class", "label": "Class",      "kind": "text",   "required": true },
            { "name": "document_date",  "label": "Date",       "kind": "text",   "required": false },
            { "name": "confidence",     "label": "Confidence", "kind": "number", "required": true },
            { "name": "reasoning",      "label": "Reasoning",  "kind": "text",   "required": false }
          ]
        }
      }
    },
    {
      "id": "route-by-class",
      "type": "decision",
      "position": { "x": 820, "y": 220 },
      "data": {
        "type": "decision",
        "label": "Route by class",
        "description": "DAG branch on classify.document_class. First matching guard wins; everything else falls through to extract_generic.",
        "conditions": [
          {
            "edgeId": "branch-lab",
            "label":  "lab_result",
            "guard":  "classify.document_class == \"lab_result\""
          },
          {
            "edgeId": "branch-rx",
            "label":  "prescription",
            "guard":  "classify.document_class == \"prescription\""
          },
          {
            "edgeId": "branch-clinical",
            "label":  "narrative clinical doc",
            "guard":  "classify.document_class in [\"referral_letter\", \"imaging_report\", \"discharge_summary\", \"consultation_note\"]"
          },
          {
            "edgeId": "branch-form",
            "label":  "admin form",
            "guard":  "classify.document_class in [\"insurance_form\", \"invoice\", \"consent_form\"]"
          }
        ],
        "defaultBranch": "branch-generic"
      }
    },
    {
      "id": "extract-bloodwork",
      "type": "automated_step",
      "position": { "x": 1100, "y": 20 },
      "data": {
        "type": "automated_step",
        "label": "Extract — Bloodwork",
        "description": "Lab-result extractor. Each row of the result table becomes one field with citations.",
        "executionSpec": {
          "backendType": "llm",
          "config": {
            "provider": "ollama",
            "model": "qwen3.5:9b",
            "base_url": "http://localhost:11435",
            "temperature": 0,
            "max_tokens": 4096,
            "system_prompt": "You are a medical lab-result extractor. Each row of the lab table = one test. Distinguish test NAME (text label like GOT, GPT, ALT, Hämoglobin, Leukozyten, Glucose) from VALUE (the number). NEVER put the test name in the value field. Every extracted field MUST carry a citations[] array with kind=ocr_span and supporting_text quoted verbatim from the OCR text.",
            "prompt": "Extract every lab value from this document.\n\nOCR text:\n---\n{{ ocr.full_text }}\n---\n\nTables (markdown):\n---\n{{ ocr.tables_text }}\n---\n\nReturn JSON: {fields: [{key, value, unit, reference_range, confidence, citations:[{kind, supporting_text, confidence}]}]}.",
            "images": [{ "path": "{{ start.document_file }}" }],
            "response_format": {
              "type": "json_schema",
              "schema": { "$ref": "#/definitions/ExtractionFields" }
            }
          }
        },
        "output": {
          "id": "out",
          "label": "Bloodwork fields",
          "fields": [
            { "name": "fields", "label": "Extracted fields", "kind": "json", "required": true }
          ]
        }
      }
    },
    {
      "id": "extract-prescription",
      "type": "automated_step",
      "position": { "x": 1100, "y": 160 },
      "data": {
        "type": "automated_step",
        "label": "Extract — Prescription",
        "description": "Prescription extractor. One field per medication.",
        "executionSpec": {
          "backendType": "llm",
          "config": {
            "provider": "ollama",
            "model": "qwen3.5:9b",
            "base_url": "http://localhost:11435",
            "temperature": 0,
            "max_tokens": 2048,
            "system_prompt": "You are a medical prescription extractor. Extract every medication with its dose, frequency, route, duration, prescriber, date, and indication. Each field MUST carry a citations[] array.",
            "prompt": "Extract all prescription details.\n\nOCR text:\n---\n{{ ocr.full_text }}\n---\n\nReturn JSON: {fields: [{key, value, unit, reference_range, confidence, citations:[{kind, supporting_text, confidence}]}]} where key ∈ {medication, dose, frequency, route, duration, prescriber, date, indication, patient_name, svnr}.",
            "images": [{ "path": "{{ start.document_file }}" }],
            "response_format": {
              "type": "json_schema",
              "schema": { "$ref": "#/definitions/ExtractionFields" }
            }
          }
        },
        "output": {
          "id": "out",
          "label": "Prescription fields",
          "fields": [
            { "name": "fields", "label": "Extracted fields", "kind": "json", "required": true }
          ]
        }
      }
    },
    {
      "id": "extract-clinical-note",
      "type": "automated_step",
      "position": { "x": 1100, "y": 300 },
      "data": {
        "type": "automated_step",
        "label": "Extract — Clinical Note",
        "description": "Narrative clinical doc extractor (referral / imaging / discharge / consultation).",
        "executionSpec": {
          "backendType": "llm",
          "config": {
            "provider": "ollama",
            "model": "qwen3.5:9b",
            "base_url": "http://localhost:11435",
            "temperature": 0,
            "max_tokens": 4096,
            "system_prompt": "You are a clinical document extractor. Pull structured fields out of this narrative document. For discharge/consultation include admission/discharge dates, ICD-10-coded diagnoses, procedures, meds-at-discharge, follow-up. For imaging include exam type, body region, findings, impression. Every field MUST carry a citations[] array.",
            "prompt": "Extract structured fields from this {{ classify.document_class }}.\n\nOCR text:\n---\n{{ ocr.full_text }}\n---\n\nReturn JSON: {fields: [{key, value, unit, reference_range, confidence, citations:[{kind, supporting_text, confidence}]}]}.",
            "images": [{ "path": "{{ start.document_file }}" }],
            "response_format": {
              "type": "json_schema",
              "schema": { "$ref": "#/definitions/ExtractionFields" }
            }
          }
        },
        "output": {
          "id": "out",
          "label": "Clinical fields",
          "fields": [
            { "name": "fields", "label": "Extracted fields", "kind": "json", "required": true }
          ]
        }
      }
    },
    {
      "id": "extract-form-fields",
      "type": "automated_step",
      "position": { "x": 1100, "y": 440 },
      "data": {
        "type": "automated_step",
        "label": "Extract — Form Fields",
        "description": "Administrative form extractor (insurance / invoice / consent).",
        "executionSpec": {
          "backendType": "llm",
          "config": {
            "provider": "ollama",
            "model": "qwen3.5:9b",
            "base_url": "http://localhost:11435",
            "temperature": 0,
            "max_tokens": 2048,
            "system_prompt": "You are a form-field extractor. Pull every labelled field out of this administrative document. Every field MUST carry a citations[] array.",
            "prompt": "Extract all labelled form fields from this {{ classify.document_class }}.\n\nOCR text:\n---\n{{ ocr.full_text }}\n---\n\nReturn JSON: {fields: [{key, value, unit, reference_range, confidence, citations:[{kind, supporting_text, confidence}]}]}.",
            "images": [{ "path": "{{ start.document_file }}" }],
            "response_format": {
              "type": "json_schema",
              "schema": { "$ref": "#/definitions/ExtractionFields" }
            }
          }
        },
        "output": {
          "id": "out",
          "label": "Form fields",
          "fields": [
            { "name": "fields", "label": "Extracted fields", "kind": "json", "required": true }
          ]
        }
      }
    },
    {
      "id": "extract-generic",
      "type": "automated_step",
      "position": { "x": 1100, "y": 580 },
      "data": {
        "type": "automated_step",
        "label": "Extract — Generic",
        "description": "Best-effort extractor for documents that did not match any specialist branch.",
        "executionSpec": {
          "backendType": "llm",
          "config": {
            "provider": "ollama",
            "model": "qwen3.5:9b",
            "base_url": "http://localhost:11435",
            "temperature": 0,
            "max_tokens": 2048,
            "system_prompt": "You are a general-purpose document extractor. Pull every identifiable structured or semi-structured field. Every field MUST carry a citations[] array.",
            "prompt": "Extract every identifiable field from this document.\n\nOCR text:\n---\n{{ ocr.full_text }}\n---\n\nReturn JSON: {fields: [{key, value, unit, reference_range, confidence, citations:[{kind, supporting_text, confidence}]}]}.",
            "images": [{ "path": "{{ start.document_file }}" }],
            "response_format": {
              "type": "json_schema",
              "schema": { "$ref": "#/definitions/ExtractionFields" }
            }
          }
        },
        "output": {
          "id": "out",
          "label": "Generic fields",
          "fields": [
            { "name": "fields", "label": "Extracted fields", "kind": "json", "required": true }
          ]
        }
      }
    },
    {
      "id": "merge-extraction",
      "type": "join",
      "slug": "extraction",
      "position": { "x": 1380, "y": 300 },
      "data": {
        "type": "join",
        "label": "Merge branches",
        "description": "Branches converge. `mode: \"any\"` — fires on the first incoming control token (XOR-join, dual of decision). The other mode, `\"all\"`, waits for every incoming branch and merges their payloads (what `parallel_join` does today). One node type, one knob — the wait-vs-fire-immediately semantics are explicit in the config, not encoded in the type name.",
        "mode": "any",
        "output": {
          "id": "out",
          "label": "Extraction",
          "fields": [
            { "name": "fields", "label": "Extracted fields", "kind": "json", "required": true }
          ]
        }
      }
    },
    {
      "id": "persist",
      "type": "automated_step",
      "position": { "x": 1620, "y": 300 },
      "data": {
        "type": "automated_step",
        "label": "Persist",
        "description": "Pick up whichever branch fired, stamp class + patient + run metadata, write a summary artifact for the downstream verifier.",
        "executionSpec": {
          "backendType": "python",
          "entrypoint": "main.py",
          "config": {
            "python": "python3",
            "requirements": [],
            "virtualenv": false,
            "sdk": true,
            "inherit_env": true,
            "env": {}
          }
        },
        "output": {
          "id": "out",
          "label": "Persisted",
          "fields": [
            { "name": "patient_data_kind", "label": "Kind",         "kind": "text",   "required": true },
            { "name": "field_count",       "label": "Field count",  "kind": "number", "required": true },
            { "name": "fields",            "label": "Fields",       "kind": "json",   "required": true }
          ]
        }
      }
    },
    {
      "id": "verify",
      "type": "automated_step",
      "position": { "x": 1880, "y": 300 },
      "data": {
        "type": "automated_step",
        "label": "Verify citations",
        "description": "Match each field's citations[].supporting_text against ocr.full_text via case-insensitive normalized substring search. The mekhan analogue of online-clinic's `provenance` step kind (`Citation::OcrSpan`, matcher=hybrid_auto).",
        "executionSpec": {
          "backendType": "python",
          "entrypoint": "main.py",
          "config": {
            "python": "python3",
            "requirements": [],
            "virtualenv": false,
            "sdk": true,
            "inherit_env": true,
            "env": {}
          }
        },
        "output": {
          "id": "out",
          "label": "Verification",
          "fields": [
            { "name": "verified_count",   "label": "Verified",    "kind": "number", "required": true },
            { "name": "unverified_count", "label": "Unverified",  "kind": "number", "required": true },
            { "name": "any_unverified",   "label": "Any issues",  "kind": "bool",   "required": true },
            { "name": "unverified_keys",  "label": "Unverified keys", "kind": "json", "required": false }
          ]
        }
      }
    },
    {
      "id": "gate",
      "type": "decision",
      "position": { "x": 2160, "y": 300 },
      "data": {
        "type": "decision",
        "label": "Needs review?",
        "description": "Send to medical-assistant review if any citation didn't verify OR if the original classification was below the per-class threshold.",
        "conditions": [
          {
            "edgeId": "branch-review",
            "label":  "review",
            "guard":  "verify.any_unverified || classify.confidence < 0.85"
          }
        ],
        "defaultBranch": "branch-clean"
      }
    },
    {
      "id": "review",
      "type": "human_task",
      "position": { "x": 2440, "y": 200 },
      "data": {
        "type": "human_task",
        "label": "Medical-assistant review",
        "taskTitle": "Review extraction — {{ classify.document_class }}",
        "instructionsMdsvex": "The extraction for patient **{{ patient_id }}** needs a quick eyes-on. Classification confidence was **{{ classify.confidence }}**; **{{ verify.unverified_count }}** field(s) failed citation verification.\n\nApprove, edit, or send back for re-OCR.",
        "steps": []
      }
    },
    {
      "id": "end-reviewed",
      "type": "end",
      "position": { "x": 2720, "y": 200 },
      "data": {
        "type": "end",
        "label": "Reviewed",
        "resultMapping": [
          { "targetField": "patient_data_kind", "expression": "persist.patient_data_kind" },
          { "targetField": "field_count",       "expression": "persist.field_count" },
          { "targetField": "verified_count",    "expression": "verify.verified_count" },
          { "targetField": "needed_review",     "expression": "true" },
          { "targetField": "ma_decision",       "expression": "review.decision" }
        ]
      }
    },
    {
      "id": "end-clean",
      "type": "end",
      "position": { "x": 2440, "y": 420 },
      "data": {
        "type": "end",
        "label": "Auto-approved",
        "resultMapping": [
          { "targetField": "patient_data_kind", "expression": "persist.patient_data_kind" },
          { "targetField": "field_count",       "expression": "persist.field_count" },
          { "targetField": "verified_count",    "expression": "verify.verified_count" },
          { "targetField": "needed_review",     "expression": "false" }
        ]
      }
    }
  ],
  "edges": [
    { "id": "e-trigger-start",    "source": "trigger-intake",  "target": "start",                "targetHandle": "in", "type": "sequence" },
    { "id": "e-start-ocr",        "source": "start",           "target": "ocr",                  "targetHandle": "in", "type": "sequence" },
    { "id": "e-ocr-classify",     "source": "ocr",             "target": "classify",             "targetHandle": "in", "type": "sequence" },
    { "id": "e-classify-route",   "source": "classify",        "target": "route-by-class",       "targetHandle": "in", "type": "sequence" },

    { "id": "e-route-lab",        "source": "route-by-class",  "target": "extract-bloodwork",    "sourceHandle": "branch-lab",      "targetHandle": "in", "label": "lab_result",      "type": "conditional" },
    { "id": "e-route-rx",         "source": "route-by-class",  "target": "extract-prescription", "sourceHandle": "branch-rx",       "targetHandle": "in", "label": "prescription",    "type": "conditional" },
    { "id": "e-route-clinical",   "source": "route-by-class",  "target": "extract-clinical-note","sourceHandle": "branch-clinical", "targetHandle": "in", "label": "clinical narrative","type": "conditional" },
    { "id": "e-route-form",       "source": "route-by-class",  "target": "extract-form-fields",  "sourceHandle": "branch-form",     "targetHandle": "in", "label": "admin form",      "type": "conditional" },
    { "id": "e-route-generic",    "source": "route-by-class",  "target": "extract-generic",      "sourceHandle": "branch-generic",  "targetHandle": "in", "label": "default",         "type": "conditional" },

    { "id": "e-bloodwork-merge", "source": "extract-bloodwork",    "target": "merge-extraction", "targetHandle": "in", "type": "sequence" },
    { "id": "e-rx-merge",        "source": "extract-prescription", "target": "merge-extraction", "targetHandle": "in", "type": "sequence" },
    { "id": "e-clinical-merge",  "source": "extract-clinical-note","target": "merge-extraction", "targetHandle": "in", "type": "sequence" },
    { "id": "e-form-merge",      "source": "extract-form-fields",  "target": "merge-extraction", "targetHandle": "in", "type": "sequence" },
    { "id": "e-generic-merge",   "source": "extract-generic",      "target": "merge-extraction", "targetHandle": "in", "type": "sequence" },

    { "id": "e-merge-persist",    "source": "merge-extraction","target": "persist",              "targetHandle": "in", "type": "sequence" },
    { "id": "e-persist-verify",   "source": "persist",         "target": "verify",               "targetHandle": "in", "type": "sequence" },
    { "id": "e-verify-gate",      "source": "verify",          "target": "gate",                 "targetHandle": "in", "type": "sequence" },

    { "id": "e-gate-review",      "source": "gate",            "target": "review",               "sourceHandle": "branch-review", "targetHandle": "in", "label": "needs review",   "type": "conditional" },
    { "id": "e-gate-clean",       "source": "gate",            "target": "end-clean",            "sourceHandle": "branch-clean",  "targetHandle": "in", "label": "auto-approved",  "type": "conditional" },

    { "id": "e-review-end",       "source": "review",          "target": "end-reviewed",         "targetHandle": "in", "type": "sequence" }
  ],
  "definitions": {
    "ExtractionFields": {
      "type": "object",
      "required": ["fields"],
      "properties": {
        "fields": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["key", "value", "confidence", "citations"],
            "properties": {
              "key":             { "type": "string" },
              "value":           { "type": "string" },
              "unit":            { "type": ["string", "null"] },
              "reference_range": { "type": ["string", "null"] },
              "confidence":      { "type": "number", "minimum": 0, "maximum": 1 },
              "citations": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "object",
                  "required": ["kind", "supporting_text"],
                  "properties": {
                    "kind":            { "type": "string", "enum": ["ocr_span"] },
                    "supporting_text": { "type": "string" },
                    "confidence":      { "type": "number", "minimum": 0, "maximum": 1 }
                  },
                  "additionalProperties": false
                }
              }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    }
  }
}
