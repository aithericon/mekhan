{
  "nodes": [
    {
      "id": "trigger-intake",
      "type": "trigger",
      "position": {
        "x": 52,
        "y": 60
      },
      "data": {
        "type": "trigger",
        "label": "Intake API",
        "source": {
          "kind": "manual",
          "form": []
        },
        "concurrency": "allow",
        "payloadMapping": [
          {
            "targetField": "document_file",
            "expression": "document_file"
          },
          {
            "targetField": "patient_id",
            "expression": "patient_id"
          }
        ],
        "enabled": true
      }
    },
    {
      "id": "start",
      "type": "start",
      "position": {
        "x": 52,
        "y": 330
      },
      "data": {
        "type": "start",
        "label": "Start",
        "processName": "Document intake — patient {{ patient_id }}",
        "initial": {
          "id": "in",
          "label": "Document Intake",
          "fields": [
            {
              "name": "document_file",
              "label": "Document (PDF, PNG, JPG)",
              "kind": "file",
              "required": true,
              "accept": "application/pdf,image/png,image/jpeg,image/webp"
            },
            {
              "name": "patient_id",
              "label": "Patient ID",
              "kind": "text",
              "required": true
            }
          ]
        }
      }
    },
    {
      "id": "ocr",
      "type": "automated_step",
      "position": {
        "x": 364,
        "y": 330
      },
      "data": {
        "type": "automated_step",
        "label": "OCR (kreuzberg)",
        "description": "Extract text + tables + metadata from the uploaded document. Tesseract backend with German+English models and table detection enabled. Outputs are kreuzberg's native ExtractionResult shape 1:1 — `content`, `mime_type`, `metadata`, `tables`, `detected_languages`. No renaming or remapping.",
        "executionSpec": {
          "backendType": "kreuzberg",
          "config": {
            "mode": "single",
            "file": "{{ start.document_file }}",
            "force_ocr": false,
            "ocr": {
              "backend": "tesseract",
              "language": "deu+eng",
              "enable_table_detection": true
            },
            "pdf": {
              "passwords": []
            }
          }
        },
        "output": {
          "id": "out",
          "label": "OCR result",
          "fields": [
            {
              "name": "content",
              "label": "Content",
              "kind": "text",
              "required": true
            },
            {
              "name": "tables",
              "label": "Tables",
              "kind": "json",
              "required": false
            },
            {
              "name": "metadata",
              "label": "Metadata",
              "kind": "json",
              "required": false
            }
          ]
        }
      }
    },
    {
      "id": "classify",
      "type": "agent",
      "position": {
        "x": 702,
        "y": 330
      },
      "data": {
        "type": "agent",
        "label": "Classify (vision LLM)",
        "description": "Vision MoE: looks at the document image and the OCR text together, returns one of the canonical document classes plus a confidence.",
        "model": {
          "provider": "ollama",
          "model": "llama3.2-vision:11b",
          "baseUrl": "http://localhost:11434",
          "temperature": 0,
          "maxTokens": 512
        },
        "userPrompt": "Classify this medical document into ONE of: lab_result, prescription, referral_letter, imaging_report, discharge_summary, consultation_note, insurance_form, invoice, consent_form, other.\n\nOCR text (supplementary, truncated to 4000 chars):\n---\n{{ ocr.content }}\n---\n\nReturn JSON: {document_class, document_date (YYYY-MM-DD or null), confidence (0..1), reasoning}.",
        "systemPrompt": "You are a medical document classification assistant. Look at the document image and the OCR text. Group the page(s) into a single logical document and classify it.",
        "responseFormat": {
          "type": "json_schema",
          "schema": {
            "type": "object",
            "required": [
              "document_class",
              "confidence",
              "reasoning"
            ],
            "properties": {
              "document_class": {
                "type": "string",
                "enum": [
                  "lab_result",
                  "prescription",
                  "referral_letter",
                  "imaging_report",
                  "discharge_summary",
                  "consultation_note",
                  "insurance_form",
                  "invoice",
                  "consent_form",
                  "other"
                ]
              },
              "document_date": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "confidence": {
                "type": "number",
                "minimum": 0,
                "maximum": 1
              },
              "reasoning": {
                "type": "string"
              }
            },
            "additionalProperties": false
          }
        },
        "images": [
          {
            "path": "{{ start.document_file }}"
          }
        ],
        "maxTurns": 1
      }
    },
    {
      "id": "route-by-class",
      "type": "decision",
      "position": {
        "x": 1066,
        "y": 330
      },
      "data": {
        "type": "decision",
        "label": "Route by class",
        "description": "DAG branch on classify.document_class. First matching guard wins; everything else falls through to extract_generic.",
        "conditions": [
          {
            "edgeId": "branch-lab",
            "label": "lab_result",
            "guard": "classify.document_class == \"lab_result\""
          },
          {
            "edgeId": "branch-rx",
            "label": "prescription",
            "guard": "classify.document_class == \"prescription\""
          },
          {
            "edgeId": "branch-clinical",
            "label": "narrative clinical doc",
            "guard": "classify.document_class in [\"referral_letter\", \"imaging_report\", \"discharge_summary\", \"consultation_note\"]"
          },
          {
            "edgeId": "branch-form",
            "label": "admin form",
            "guard": "classify.document_class in [\"insurance_form\", \"invoice\", \"consent_form\"]"
          }
        ],
        "defaultBranch": "default"
      }
    },
    {
      "id": "extract-bloodwork",
      "type": "agent",
      "position": {
        "x": 1430,
        "y": 30
      },
      "data": {
        "type": "agent",
        "label": "Extract — Bloodwork",
        "description": "Lab-result extractor. Each row of the result table becomes one field with citations.",
        "model": {
          "provider": "ollama",
          "model": "qwen3.5:9b",
          "baseUrl": "http://localhost:11434",
          "temperature": 0,
          "maxTokens": 4096
        },
        "userPrompt": "Extract every lab value from this document.\n\nOCR text:\n---\n{{ ocr.content }}\n---\n\nTables (JSON; each entry has `markdown`, `cells`, `page_number`):\n---\n{{ ocr.tables }}\n---\n\nReturn JSON: {fields: [{key, value, unit, reference_range, confidence, citations:[{kind, supporting_text, confidence}]}]}.",
        "systemPrompt": "You are a medical lab-result extractor. Each row of the lab table = one test. Distinguish test NAME (text label like GOT, GPT, ALT, Hämoglobin, Leukozyten, Glucose) from VALUE (the number). NEVER put the test name in the value field. Every extracted field MUST carry a citations[] array with kind=ocr_span and supporting_text quoted verbatim from the OCR text.",
        "responseFormat": {
          "type": "json_schema",
          "schema": {
            "$ref": "#/definitions/ExtractionFields"
          }
        },
        "images": [
          {
            "path": "{{ start.document_file }}"
          }
        ],
        "maxTurns": 1
      }
    },
    {
      "id": "extract-prescription",
      "type": "agent",
      "position": {
        "x": 1430,
        "y": 240
      },
      "data": {
        "type": "agent",
        "label": "Extract — Prescription",
        "description": "Prescription extractor. One field per medication.",
        "model": {
          "provider": "ollama",
          "model": "qwen3.5:9b",
          "baseUrl": "http://localhost:11434",
          "temperature": 0,
          "maxTokens": 2048
        },
        "userPrompt": "Extract all prescription details.\n\nOCR text:\n---\n{{ ocr.content }}\n---\n\nReturn JSON: {fields: [{key, value, unit, reference_range, confidence, citations:[{kind, supporting_text, confidence}]}]} where key ∈ {medication, dose, frequency, route, duration, prescriber, date, indication, patient_name, svnr}.",
        "systemPrompt": "You are a medical prescription extractor. Extract every medication with its dose, frequency, route, duration, prescriber, date, and indication. Each field MUST carry a citations[] array.",
        "responseFormat": {
          "type": "json_schema",
          "schema": {
            "$ref": "#/definitions/ExtractionFields"
          }
        },
        "images": [
          {
            "path": "{{ start.document_file }}"
          }
        ],
        "maxTurns": 1
      }
    },
    {
      "id": "extract-clinical-note",
      "type": "agent",
      "position": {
        "x": 1430,
        "y": 450
      },
      "data": {
        "type": "agent",
        "label": "Extract — Clinical Note",
        "description": "Narrative clinical doc extractor (referral / imaging / discharge / consultation).",
        "model": {
          "provider": "ollama",
          "model": "qwen3.5:9b",
          "baseUrl": "http://localhost:11434",
          "temperature": 0,
          "maxTokens": 4096
        },
        "userPrompt": "Extract structured fields from this {{ classify.document_class }}.\n\nOCR text:\n---\n{{ ocr.content }}\n---\n\nReturn JSON: {fields: [{key, value, unit, reference_range, confidence, citations:[{kind, supporting_text, confidence}]}]}.",
        "systemPrompt": "You are a clinical document extractor. Pull structured fields out of this narrative document. For discharge/consultation include admission/discharge dates, ICD-10-coded diagnoses, procedures, meds-at-discharge, follow-up. For imaging include exam type, body region, findings, impression. Every field MUST carry a citations[] array.",
        "responseFormat": {
          "type": "json_schema",
          "schema": {
            "$ref": "#/definitions/ExtractionFields"
          }
        },
        "images": [
          {
            "path": "{{ start.document_file }}"
          }
        ],
        "maxTurns": 1
      }
    },
    {
      "id": "extract-form-fields",
      "type": "agent",
      "position": {
        "x": 1430,
        "y": 660
      },
      "data": {
        "type": "agent",
        "label": "Extract — Form Fields",
        "description": "Administrative form extractor (insurance / invoice / consent).",
        "model": {
          "provider": "ollama",
          "model": "qwen3.5:9b",
          "baseUrl": "http://localhost:11434",
          "temperature": 0,
          "maxTokens": 2048
        },
        "userPrompt": "Extract all labelled form fields from this {{ classify.document_class }}.\n\nOCR text:\n---\n{{ ocr.content }}\n---\n\nReturn JSON: {fields: [{key, value, unit, reference_range, confidence, citations:[{kind, supporting_text, confidence}]}]}.",
        "systemPrompt": "You are a form-field extractor. Pull every labelled field out of this administrative document. Every field MUST carry a citations[] array.",
        "responseFormat": {
          "type": "json_schema",
          "schema": {
            "$ref": "#/definitions/ExtractionFields"
          }
        },
        "images": [
          {
            "path": "{{ start.document_file }}"
          }
        ],
        "maxTurns": 1
      }
    },
    {
      "id": "extract-generic",
      "type": "agent",
      "position": {
        "x": 1430,
        "y": 870
      },
      "data": {
        "type": "agent",
        "label": "Extract — Generic",
        "description": "Best-effort extractor for documents that did not match any specialist branch.",
        "model": {
          "provider": "ollama",
          "model": "qwen3.5:9b",
          "baseUrl": "http://localhost:11434",
          "temperature": 0,
          "maxTokens": 2048
        },
        "userPrompt": "Extract every identifiable field from this document.\n\nOCR text:\n---\n{{ ocr.content }}\n---\n\nReturn JSON: {fields: [{key, value, unit, reference_range, confidence, citations:[{kind, supporting_text, confidence}]}]}.",
        "systemPrompt": "You are a general-purpose document extractor. Pull every identifiable structured or semi-structured field. Every field MUST carry a citations[] array.",
        "responseFormat": {
          "type": "json_schema",
          "schema": {
            "$ref": "#/definitions/ExtractionFields"
          }
        },
        "images": [
          {
            "path": "{{ start.document_file }}"
          }
        ],
        "maxTurns": 1
      }
    },
    {
      "id": "merge-extraction",
      "type": "join",
      "slug": "extraction",
      "position": {
        "x": 1794,
        "y": 450
      },
      "data": {
        "type": "join",
        "label": "Merge branches",
        "description": "Branches converge. `mode: \"any\"` — fires on the first incoming control token (XOR-join, dual of decision). The other mode, `\"all\"`, waits for every incoming branch and merges their payloads (AND-join). One node type, one knob — the wait-vs-fire-immediately semantics are explicit in the config, not encoded in the type name.",
        "mode": "any",
        "output": {
          "id": "out",
          "label": "Extraction",
          "fields": [
            {
              "name": "fields",
              "label": "Extracted fields",
              "kind": "json",
              "required": true
            }
          ]
        }
      }
    },
    {
      "id": "persist",
      "type": "automated_step",
      "position": {
        "x": 2106,
        "y": 450
      },
      "data": {
        "type": "automated_step",
        "label": "Persist",
        "description": "Pick up whichever branch fired, stamp class + patient + run metadata, write a summary artifact for the downstream verifier.",
        "executionSpec": {
          "backendType": "python",
          "entrypoint": "main.py",
          "config": {
            "python": "python3",
            "requirements": [],
            "virtualenv": false,
            "sdk": true,
            "inherit_env": true,
            "env": {}
          }
        },
        "output": {
          "id": "out",
          "label": "Persisted",
          "fields": [
            {
              "name": "patient_data_kind",
              "label": "Kind",
              "kind": "text",
              "required": true
            },
            {
              "name": "field_count",
              "label": "Field count",
              "kind": "number",
              "required": true
            },
            {
              "name": "fields",
              "label": "Fields",
              "kind": "json",
              "required": true
            },
            {
              "name": "summary_table",
              "label": "Summary (markdown table)",
              "kind": "text",
              "required": false
            }
          ]
        }
      }
    },
    {
      "id": "verify",
      "type": "automated_step",
      "position": {
        "x": 2444,
        "y": 450
      },
      "data": {
        "type": "automated_step",
        "label": "Verify citations",
        "description": "Match each field's citations[].supporting_text against ocr.content via case-insensitive normalized substring search. The mekhan analogue of online-clinic's `provenance` step kind (`Citation::OcrSpan`, matcher=hybrid_auto).",
        "executionSpec": {
          "backendType": "python",
          "entrypoint": "main.py",
          "config": {
            "python": "python3",
            "requirements": [],
            "virtualenv": false,
            "sdk": true,
            "inherit_env": true,
            "env": {}
          }
        },
        "output": {
          "id": "out",
          "label": "Verification",
          "fields": [
            {
              "name": "verified_count",
              "label": "Verified",
              "kind": "number",
              "required": true
            },
            {
              "name": "unverified_count",
              "label": "Unverified",
              "kind": "number",
              "required": true
            },
            {
              "name": "any_unverified",
              "label": "Any issues",
              "kind": "bool",
              "required": true
            },
            {
              "name": "unverified_keys",
              "label": "Unverified keys",
              "kind": "json",
              "required": false
            }
          ]
        }
      }
    },
    {
      "id": "gate",
      "type": "decision",
      "position": {
        "x": 2808,
        "y": 450
      },
      "data": {
        "type": "decision",
        "label": "Needs review?",
        "description": "Send to medical-assistant review if any citation didn't verify OR if the original classification was below the per-class threshold.",
        "conditions": [
          {
            "edgeId": "branch-review",
            "label": "review",
            "guard": "verify.any_unverified || classify.confidence < 0.85"
          }
        ],
        "defaultBranch": "default"
      }
    },
    {
      "id": "review",
      "type": "human_task",
      "position": {
        "x": 3172,
        "y": 300
      },
      "data": {
        "type": "human_task",
        "label": "Medical-assistant review",
        "taskTitle": "Review extraction — {{ classify.document_class }}",
        "instructionsMdsvex": "The extraction for patient **{{ patient_id }}** needs a quick eyes-on. Classification confidence was **{{ classify.confidence }}**; **{{ verify.unverified_count }}** field(s) failed citation verification.\n\nApprove, edit, or send back for re-OCR.",
        "steps": []
      }
    },
    {
      "id": "end-reviewed",
      "type": "end",
      "position": {
        "x": 3536,
        "y": 300
      },
      "data": {
        "type": "end",
        "label": "Reviewed",
        "resultMapping": [
          {
            "targetField": "patient_data_kind",
            "expression": "persist.patient_data_kind"
          },
          {
            "targetField": "field_count",
            "expression": "persist.field_count"
          },
          {
            "targetField": "verified_count",
            "expression": "verify.verified_count"
          },
          {
            "targetField": "needed_review",
            "expression": "true"
          },
          {
            "targetField": "ma_decision",
            "expression": "review.decision"
          }
        ]
      }
    },
    {
      "id": "end-clean",
      "type": "end",
      "position": {
        "x": 3172,
        "y": 630
      },
      "data": {
        "type": "end",
        "label": "Auto-approved",
        "resultMapping": [
          {
            "targetField": "patient_data_kind",
            "expression": "persist.patient_data_kind"
          },
          {
            "targetField": "field_count",
            "expression": "persist.field_count"
          },
          {
            "targetField": "verified_count",
            "expression": "verify.verified_count"
          },
          {
            "targetField": "needed_review",
            "expression": "false"
          }
        ]
      }
    }
  ],
  "edges": [
