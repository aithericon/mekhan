{
  "name": "finds-pushed-lines",
  "enabled": true,
  "start_tokens": [
    {
      "start_block_id": "start",
      "token": { "app": "varlogs-demo", "since": "1h" }
    }
  ],
  "human_answers": {},
  "assertions": [
    {
      "path": "result.value.entry_count",
      "op": "gte",
      "value": 1
    },
    {
      "path": "result.value.entries",
      "op": "exists"
    },
    {
      "path": "result.value.result_type",
      "op": "eq",
      "value": "streams"
    }
  ]
}
