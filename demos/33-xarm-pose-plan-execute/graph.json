{
  "nodes": [
    {
      "id": "start",
      "type": "start",
      "position": { "x": 0, "y": 153 },
      "data": {
        "type": "start",
        "label": "Start",
        "processName": "xArm Pose Plan → Execute",
        "initial": { "id": "in", "label": "Begin", "fields": [] }
      }
    },
    {
      "id": "plan_pose",
      "type": "automated_step",
      "slug": "plan_pose",
      "position": { "x": 190, "y": 50 },
      "data": {
        "type": "automated_step",
        "label": "Plan to Pose (MoveIt)",
        "description": "ROS `call_service` to `/plan_to_pose` (`aithericon_motion_bridge/srv/PlanToPose`) — the runner-side Path C motion-bridge node. Unlike the stock `xarm_pose_plan` (which stashes the plan internally and returns only `{success}`), this bridge calls MoveIt's OWN services (`/compute_ik` GetPositionIK → a joint solution, then `/plan_kinematic_path` GetMotionPlan with hand-built JointConstraints) and RETURNS the planned trajectory as a referenceable output. The response object's keys are promoted to top-level node outputs: `trajectory` (the inner trajectory_msgs/JointTrajectory as an opaque JSON blob, spliced verbatim into Path B), plus a typed metrics sidecar (`success`, `planning_time`, `point_count`, `total_duration`, `error_code`, `error_message`) the Decision gate keys off. Runs on an `xarm_fleet` runner satisfying `ros.robot_model == xarm6`; the embedded `interface_typedefs` (request + response) let the deriver shape the output port live for this non-bundled service.",
        "deploymentModel": { "mode": "executor", "capacity": { "alias": "xarm_fleet" } },
        "requirements": {
          "constraints": [
            { "capability": "ros", "field": "robot_model", "op": "eq", "value": "xarm6" }
          ]
        },
        "executionSpec": {
          "backendType": "ros",
          "config": {
            "operation": "call_service",
            "interface_name": "/plan_to_pose",
            "interface_type": "aithericon_motion_bridge/srv/PlanToPose",
            "fields": {
              "target": {
                "position": { "x": 0.3, "y": 0.0, "z": 0.4 },
                "orientation": { "x": 1.0, "y": 0.0, "z": 0.0, "w": 0.0 }
              },
              "group": "xarm6",
              "frame_id": "link_base",
              "allowed_planning_time": 5.0,
              "num_planning_attempts": 10
            },
            "interface_typedefs": [
              {
                "type": "aithericon_motion_bridge/PlanToPose_Request",
                "fieldnames": ["target", "group", "frame_id", "allowed_planning_time", "num_planning_attempts"],
                "fieldtypes": ["geometry_msgs/Pose", "string", "string", "double", "int32"],
                "fieldarraylen": [-1, -1, -1, -1, -1]
              },
              {
                "type": "aithericon_motion_bridge/PlanToPose_Response",
                "fieldnames": ["success", "trajectory", "planning_time", "point_count", "total_duration", "error_code", "error_message"],
                "fieldtypes": ["boolean", "string", "double", "int32", "double", "int32", "string"],
                "fieldarraylen": [-1, -1, -1, -1, -1, -1, -1]
              }
            ]
          }
        },
        "output": {
          "id": "out",
          "label": "Output",
          "fields": [
            { "name": "trajectory", "label": "Trajectory (opaque JSON-encoded JointTrajectory)", "kind": "text" },
            { "name": "success", "label": "Success", "kind": "bool" },
            { "name": "planning_time", "label": "Planning time (s)", "kind": "number" },
            { "name": "point_count", "label": "Point count", "kind": "number" },
            { "name": "total_duration", "label": "Total duration (s)", "kind": "number" }
          ]
        },
        "retryPolicy": { "maxRetries": 0, "backoff": "immediate" }
      }
    },
    {
      "id": "gate",
      "type": "decision",
      "slug": "gate",
      "position": { "x": 500, "y": 117 },
      "data": {
        "type": "decision",
        "label": "Plan acceptable?",
        "description": "Compiler-checked gate on the typed metrics sidecar from `plan_pose`. Accept only a successful plan with at least one trajectory point and a total duration within 30s; everything else routes to `end-rejected` (execute never fires). Each `<slug>.<field>` ref is resolved against `plan_pose`'s declared output port at compile time — a sidecar field-name typo fails pre-publish.",
        "conditions": [
          {
            "edgeId": "branch-accept",
            "label": "Accept",
            "guard": "plan_pose.success == true && plan_pose.point_count > 0 && plan_pose.total_duration <= 30.0"
          }
        ],
        "defaultBranch": "default"
      }
    },
    {
      "id": "execute",
      "type": "automated_step",
      "slug": "execute",
      "position": { "x": 810, "y": 198 },
      "data": {
        "type": "automated_step",
        "label": "Execute Trajectory (Path B)",
        "description": "ROS `send_action_goal` to `/xarm6_traj_controller/follow_joint_trajectory` (`control_msgs/action/FollowJointTrajectory`) — the already-shipped Path B execution primitive. The planned trajectory is spliced verbatim as the BARE whole-object placeholder `{{ plan_pose.trajectory }}` (the only content of the `trajectory` field, so the backend's `is_pure_placeholder` path re-parses the rendered JSON object and adopts the typed value with zero reshaping). The action's terminal RESULT rides `stdout_tail`, NOT outputs — so `error_code` is NOT mapped here; only the live feedback count is a referenceable output. Runs on the same `xarm_fleet` runner.",
        "deploymentModel": { "mode": "executor", "capacity": { "alias": "xarm_fleet" } },
        "requirements": {
          "constraints": [
            { "capability": "ros", "field": "robot_model", "op": "eq", "value": "xarm6" }
          ]
        },
        "executionSpec": {
          "backendType": "ros",
          "config": {
            "operation": "send_action_goal",
            "interface_name": "/xarm6_traj_controller/follow_joint_trajectory",
            "interface_type": "control_msgs/action/FollowJointTrajectory",
            "fields": {
              "trajectory": "{{ plan_pose.trajectory }}"
            },
            "interface_typedefs": [
              {
                "type": "control_msgs/FollowJointTrajectory_Result",
                "fieldnames": ["error_code", "error_string"],
                "fieldtypes": ["int32", "string"],
                "fieldarraylen": [-1, -1]
              }
            ]
          }
        },
        "output": {
          "id": "out",
          "label": "Output",
          "fields": [
            { "name": "feedback_count", "label": "Feedback count", "kind": "number" }
          ]
        },
        "retryPolicy": { "maxRetries": 0, "backoff": "immediate" }
      }
    },
    {
      "id": "read_state",
      "type": "automated_step",
      "slug": "read_state",
      "position": { "x": 1120, "y": 144 },
      "data": {
        "type": "automated_step",
        "label": "Read Joint State",
        "description": "ROS `await_topic` on `/joint_states` (`sensor_msgs/msg/JointState`). Captures where the arm ended up after executing the planned trajectory — a non-empty `positions` readback proves the spliced whole-object trajectory actually drove the arm. Array output fields (`name`/`position`/`velocity`/`effort`) derive to Json ports with array schema overrides; numeric leaves are nullable because rosbridge renders the fake controller's NaN `effort` as JSON null.",
        "deploymentModel": { "mode": "executor", "capacity": { "alias": "xarm_fleet" } },
        "requirements": {
          "constraints": [
            { "capability": "ros", "field": "robot_model", "op": "eq", "value": "xarm6" }
          ]
        },
        "executionSpec": {
          "backendType": "ros",
          "config": {
            "operation": "await_topic",
            "interface_name": "/joint_states",
            "interface_type": "sensor_msgs/msg/JointState",
            "fields": {},
            "interface_typedefs": [
              { "type": "sensor_msgs/JointState", "fieldnames": ["header", "name", "position", "velocity", "effort"], "fieldtypes": ["std_msgs/Header", "string", "double", "double", "double"], "fieldarraylen": [-1, 0, 0, 0, 0] },
              { "type": "std_msgs/Header", "fieldnames": ["stamp", "frame_id"], "fieldtypes": ["builtin_interfaces/Time", "string"], "fieldarraylen": [-1, -1] },
              { "type": "builtin_interfaces/Time", "fieldnames": ["sec", "nanosec"], "fieldtypes": ["int32", "uint32"], "fieldarraylen": [-1, -1] }
            ]
          }
        },
        "output": {
          "id": "out",
          "label": "Output",
          "fields": [
            { "name": "header", "label": "Header", "kind": "json", "schema": { "type": "object", "properties": { "stamp": {}, "frame_id": { "type": "string" } } } },
            { "name": "name", "label": "Name", "kind": "json", "schema": { "type": "array", "items": { "type": "string" } } },
            { "name": "position", "label": "Position", "kind": "json", "schema": { "type": "array", "items": { "type": ["number", "null"] } } },
            { "name": "velocity", "label": "Velocity", "kind": "json", "schema": { "type": "array", "items": { "type": ["number", "null"] } } },
            { "name": "effort", "label": "Effort", "kind": "json", "schema": { "type": "array", "items": { "type": ["number", "null"] } } }
          ]
        },
        "retryPolicy": { "maxRetries": 0, "backoff": "immediate" }
      }
    },
    {
      "id": "end-done",
      "type": "end",
      "position": { "x": 1430, "y": 147 },
      "data": {
        "type": "end",
        "label": "Done",
        "resultMapping": [
          { "targetField": "planned", "expression": "true" },
          { "targetField": "plan_ok", "expression": "plan_pose.success" },
          { "targetField": "planning_time", "expression": "plan_pose.planning_time" },
          { "targetField": "point_count", "expression": "plan_pose.point_count" },
          { "targetField": "joint_names", "expression": "read_state.name" },
          { "targetField": "positions", "expression": "read_state.position" }
        ]
      }
    },
    {
      "id": "end-rejected",
      "type": "end",
      "position": { "x": 820, "y": 0 },
      "data": {
        "type": "end",
        "label": "Plan Rejected",
        "resultMapping": [
          { "targetField": "planned", "expression": "false" },
          { "targetField": "reason", "expression": "\"plan_rejected\"" },
          { "targetField": "point_count", "expression": "plan_pose.point_count" }
        ]
      }
    }
  ],
  "edges": [
    { "id": "e_start_plan", "source": "start", "target": "plan_pose", "targetHandle": "in", "type": "sequence" },
    { "id": "e_plan_gate", "source": "plan_pose", "target": "gate", "targetHandle": "in", "type": "sequence" },
    { "id": "e_gate_execute", "source": "gate", "target": "execute", "targetHandle": "in", "sourceHandle": "branch-accept", "label": "Accept", "type": "conditional" },
    { "id": "e_gate_rejected", "source": "gate", "target": "end-rejected", "targetHandle": "in", "sourceHandle": "default", "label": "Reject", "type": "conditional" },
    { "id": "e_execute_read", "source": "execute", "target": "read_state", "targetHandle": "in", "type": "sequence" },
    { "id": "e_read_done", "source": "read_state", "target": "end-done", "targetHandle": "in", "type": "sequence" }
  ]
}
