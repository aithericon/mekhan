      "width": 360,
      "height": 300,
      "data": {
        "type": "timeout",
        "label": "Review SLA",
        "description": "Races the body (a HumanTask) against a 30s deadline. If the reviewer responds in time, the token flows out the default `done` handle. If the timer wins, the engine fires `human_cancel` on the in-flight task (drained automatically) and the token flows out the `timeout` handle. Body wiring: `sla --body_in--> review` and `review --body_out--> sla`.",
        "durationMsExpr": "30000"
      }
    },
    {
      "id": "review",
      "type": "human_task",
      "slug": "review",
      "position": { "x": 440, "y": 320 },
