      "data": {
        "type": "automated_step",
        "label": "Query Up",
        "description": "Prometheus `query` backend. Runs the instant PromQL query `up` against the `demo_prometheus` resource at the current evaluation time (instant query: no time window — the latest sample per series). `up` is the per-target scrape-health metric Prometheus exposes for every scrape job, so a stock `prom/prometheus` that self-scrapes always has at least one `up` series with no push step required. Output is the fixed Prometheus envelope: `result_type`, `series`, `samples` (array of {metric, value, ts} for `vector` results), `sample_count`, `scalar`, `stats`.",
        "executionSpec": {
          "backendType": "prometheus",
          "config": {
            "resource_alias": "demo_prometheus",
            "operation": "query",
            "query": "up"
          }
        },
        "output": {
          "id": "out",
          "label": "Metrics",
          "fields": [
            { "name": "result_type", "label": "Result type", "kind": "text" },
            { "name": "series", "label": "Series", "kind": "json" },
            { "name": "samples", "label": "Samples", "kind": "json" },
            { "name": "sample_count", "label": "Sample count", "kind": "number" },
            { "name": "scalar", "label": "Scalar", "kind": "json" },
            { "name": "stats", "label": "Stats", "kind": "json" }
          ]
        },
        "retryPolicy": {
          "maxRetries": 0,
          "strategy": { "type": "immediate" }
        },
        "deploymentModel": { "mode": "executor" }
      }
    },
