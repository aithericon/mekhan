                      -0.351,
                      -0.698,
                      0.001,
                      1.049,
                      0.279
                    ],
                    "time_from_start": {
                      "sec": 0,
                      "nanosec": 0
                    }
                  },
                  {
                    "positions": [
                      0.279,
                      -0.8,
                      -0.4,
                      0.0,
                      1.0,
                      0.279
                    ],
                    "time_from_start": {
                      "sec": 4,
                      "nanosec": 0
                    }
