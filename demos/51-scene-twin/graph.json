      "position": { "x": 2442, "y": 32 },
      "data": {
        "type": "automated_step",
        "label": "Twin view (drain planning-scene stream)",
        "description": "Consumer of the `scene` data channel \u2014 the net-side anchor the live planning-scene twin renders ON (the UI taps the SAME channel out-of-band via `?follow=1`, while this node drains it on the data plane). Reads the NDJSON planning-scene frames with the ordinary transport-unaware `for chunk in stream('scene')` API, reframes on newlines, validates each frame parses, and counts complete frames. The robot model is carried in the channel content_type as `;model=xarm6` so the twin renderer knows which URDF (`robot_description` asset, ref_key xarm6) to load. The frames carry the REAL move_group scene streamed live from `exec_lift`. The bulk stream rides the out-of-band JetStream datastream transport \u2014 the net sees only open + close. Drain node copied from demo 49's `twin_view`, channel renamed `joints` \u2192 `scene`. Plain `executor`: rides the held lease.",
        "deploymentModel": {
          "mode": "executor"
        },
        "channels": [
          {
            "name": "scene",
            "direction": "in",
            "plane": "data",
            "element": {
              "type": "binary",
              "content_type": "application/vnd.aithericon.planning-scene+x-ndjson;model=xarm6"
            }
          }
        ],
        "executionSpec": {
          "backendType": "python",
          "entrypoint": "main.py",
          "config": {
            "python": "python3",
            "requirements": [],
            "virtualenv": false,
            "sdk": true,
            "inherit_env": true,
            "env": {}
          }
        },
        "output": {
          "id": "out",
          "label": "Twin view",
          "fields": [
            {
              "name": "received_frames",
              "label": "Frames received",
              "kind": "number"
            }
          ]
        },
        "retryPolicy": {
          "maxRetries": 0,
          "backoff": "immediate"
        }
      }
    },
