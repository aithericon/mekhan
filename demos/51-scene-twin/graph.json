    {
      "id": "exec_lift",
      "type": "automated_step",
      "slug": "exec_lift",
      "parentId": "lease",
      "position": { "x": 1876, "y": 32 },
      "data": {
        "type": "automated_step",
        "label": "Lift (carry grasped sample \u00b7 live scene twin)",
        "description": "ROS `send_action_goal` to `/xarm6_traj_controller/follow_joint_trajectory` (`control_msgs/action/FollowJointTrajectory`) \u2014 executes the lift planned by `plan_lift`, spliced verbatim as the BARE whole-object placeholder `{{ plan_lift.trajectory }}`. This is the TWIN PRODUCER: it ALSO declares a Data/Out channel `scene` and sets `scene_stream_ms: 200`, so as the controller follows the lift the ROS backend samples move_group's ACTUAL planning scene every ~200ms and streams each as one NDJSON frame (arm joint states + the two world boxes + `sample_a` riding the gripper) onto the channel. content_type `application/vnd.aithericon.planning-scene+x-ndjson;model=xarm6` routes the UI render registry to the planning-scene twin renderer, drawing the LIVE move_group scene on the `exec_lift` \u2192 `twin_view` edge \u2014 the REAL scene, NOT a re-computed one. The bulk scene stream rides the out-of-band JetStream datastream transport \u2014 the net sees only open + close; the action RESULT rides `stdout_tail`. Plain `executor`: rides the held lease. interface_typedefs copied verbatim from demo 37-pick's `execute`; channel shape mirrors demo 49's `move`.",
        "deploymentModel": {
          "mode": "executor"
        },
        "channels": [
          {
            "name": "scene",
            "direction": "out",
            "plane": "data",
            "element": {
              "type": "binary",
              "content_type": "application/vnd.aithericon.planning-scene+x-ndjson;model=xarm6"
            }
          }
        ],
        "executionSpec": {
          "backendType": "ros",
          "config": {
            "operation": "send_action_goal",
            "interface_name": "/xarm6_traj_controller/follow_joint_trajectory",
            "interface_type": "control_msgs/action/FollowJointTrajectory",
            "scene_stream_ms": 200,
            "fields": {
              "trajectory": {
                "joint_names": [
                  "joint1",
                  "joint2",
                  "joint3",
                  "joint4",
                  "joint5",
                  "joint6"
                ],
                "points": [
                  {
                    "positions": [
