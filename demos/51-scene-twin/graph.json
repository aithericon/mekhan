      "data": {
        "type": "lease_scope",
        "label": "xArm Scene Cell",
        "description": "Acquires ONE `xarm_fleet` runner for the whole scene-twin run and releases it on exit. Everything inside \u2014 scene clear, sample seeding, plan/execute/grasp, the lift that streams the twin, and the release \u2014 runs on the same held runner by CONTAINMENT (the body steps inherit the held `runner.<id>` namespace), so the persistent move_group planning scene seeded by `add_sample_a/b` is the SAME scene `plan_reach`/`grasp`/`exec_lift` plan against and the same scene `exec_lift` streams to the twin. The `requirements` pick WHICH runner to hold (an xArm6); body steps are plain `executor` \u2014 they do NOT claim their own unit (that would deadlock against the held one), they ride the lease.",
        "lease": {
          "pool": "xarm_fleet"
        },
        "requirements": {
          "constraints": [
            {
              "capability": "ros",
              "field": "robot_model",
              "op": "eq",
              "value": "xarm6"
            }
          ]
        }
      }
    },
    {
      "id": "reset_scene",
      "type": "automated_step",
      "slug": "reset_scene",
      "parentId": "lease",
      "position": { "x": 16, "y": 50 },
      "data": {
        "type": "automated_step",
        "label": "Reset Scene (clear move_group)",
        "description": "Cell-reset head \u2014 makes the whole run idempotent. ROS `call_service` to `/clear_scene` (`aithericon_motion_bridge/srv/ClearScene`, confirm-guarded) \u2014 removes ALL world + attached collision objects from move_group's persistent planning scene, so a re-run starts from a clean slate and any sample still attached to the gripper from a prior run is detached back into the world. Plain `executor` (NO per-step capacity): rides the enclosing cell lease's held `runner.<id>` namespace by containment, so the clear hits the SAME held move_group the seed + plan steps plan against. Runs ONCE, before seeding.",
        "deploymentModel": {
          "mode": "executor"
        },
        "executionSpec": {
          "backendType": "ros",
          "config": {
            "operation": "call_service",
            "interface_name": "/clear_scene",
            "interface_type": "aithericon_motion_bridge/srv/ClearScene",
            "fields": {
              "confirm": true
            },
            "interface_typedefs": [
              {
                "type": "aithericon_motion_bridge/ClearScene_Request",
                "fieldnames": [
                  "confirm"
                ],
                "fieldtypes": [
                  "boolean"
                ],
                "fieldarraylen": [
                  -1
                ]
              },
              {
                "type": "aithericon_motion_bridge/ClearScene_Response",
                "fieldnames": [
                  "success",
                  "removed_count",
                  "error_message"
                ],
                "fieldtypes": [
                  "boolean",
                  "int32",
                  "string"
                ],
                "fieldarraylen": [
                  -1,
                  -1,
                  -1
                ]
              }
            ]
          }
        },
        "output": {
          "id": "out",
          "label": "Output",
          "fields": [
            {
              "name": "success",
              "label": "Success",
              "kind": "bool"
            },
            {
              "name": "removed_count",
              "label": "Removed count",
              "kind": "number"
            }
          ]
        },
        "retryPolicy": {
          "maxRetries": 0,
          "backoff": "immediate"
        }
      }
    },
    {
