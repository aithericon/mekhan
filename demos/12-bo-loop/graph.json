      "slug": "start",
      "position": {
        "x": 40,
        "y": 200
      },
      "data": {
        "type": "start",
        "label": "Seed BO Campaign",
        "processName": "Bayesian Optimization",
        "initial": {
          "id": "in",
          "label": "Seed",
          "fields": [
            {
              "name": "observations",
              "label": "Initial observations",
              "kind": "json",
              "required": true
            },
            {
              "name": "f_best",
              "label": "Seed f_best",
              "kind": "number",
              "required": true
            },
            {
              "name": "max_iterations",
              "label": "Iteration budget",
              "kind": "number",
              "required": true
            }
          ]
        }
      }
    },
    {
      "id": "lp",
      "type": "loop",
      "slug": "bo",
      "position": {
        "x": 280,
        "y": 80
      },
      "width": 1100,
      "height": 420,
      "data": {
        "type": "loop",
        "label": "BO Iterations",
        "description": "Carries the campaign state across iterations: the accumulated `observations`, the incumbent `f_best`, and the best point seen (`best_a`/`best_d`). Each iteration fits a surrogate, proposes + evaluates K candidates, and folds the results in. The real stop condition is loopCondition (`bo.iteration < input.max_iterations`); maxIterations is a runaway cap.",
        "maxIterations": 30,
        "loopCondition": "bo.iteration < input.max_iterations",
        "accumulators": [
          {
            "var": "observations",
            "init": "input.observations",
            "mergeExpr": "bo.observations + gather.merged"
          },
          {
            "var": "f_best",
            "init": "input.f_best",
            "mergeExpr": "gather.new_f_best"
          },
          {
            "var": "best_a",
            "init": "0.0",
            "mergeExpr": "gather.new_best_a"
          },
          {
            "var": "best_d",
            "init": "0.0",
            "mergeExpr": "gather.new_best_d"
          }
        ]
      }
    },
    {
      "id": "propose",
      "type": "automated_step",
      "slug": "propose",
      "parentId": "lp",
      "position": {
        "x": 40,
        "y": 80
      },
      "data": {
        "type": "automated_step",
        "label": "Fit GP + propose K candidates",
        "description": "Reads the accumulated `bo.observations`, the incumbent `bo.f_best`, and `bo.iteration`, fits a surrogate, and emits a batch of K candidate points to evaluate. (Placeholder proposer for this phase; the GP/acquisition code lands next.)",
        "executionSpec": {
          "backendType": "python",
          "entrypoint": "main.py",
          "config": {
            "python": "python3",
            "requirements": [
              "numpy",
              "scipy",
              "scikit-learn"
            ],
            "virtualenv": false,
            "sdk": true,
            "inherit_env": true,
            "env": {}
          }
        },
        "output": {
          "id": "out",
          "label": "Proposals",
          "fields": [
            {
              "name": "candidates",
              "label": "Candidate batch",
              "kind": "json",
              "required": true
            }
          ]
        }
      }
    },
    {
      "id": "mp",
      "type": "map",
      "slug": "evals",
      "parentId": "lp",
      "position": {
        "x": 380,
        "y": 120
      },
      "width": 520,
      "height": 200,
      "data": {
        "type": "map",
        "label": "Evaluate K candidates",
        "description": "Scatters `propose.candidates` into one body token per candidate and runs the `branin` objective once per element (data-parallel). Gathers the per-candidate observations into the `evals` collection, borrowed downstream as `evals[*].obs`.",
        "itemsRef": "propose.candidates",
        "itemVar": "cand",
        "resultVar": "obs",
        "output": {
          "id": "out",
          "label": "Eval",
          "fields": [
            {
              "name": "obs",
              "label": "Observation",
              "kind": "json",
              "required": true
            }
          ]
        }
      }
    },
    {
      "id": "branin",
      "type": "automated_step",
      "slug": "branin",
      "parentId": "mp",
      "position": {
        "x": 40,
        "y": 60
      },
      "data": {
        "type": "automated_step",
        "label": "Branin objective",
        "description": "Map body. Reads the per-candidate `cand.a` / `cand.d` (token-resident itemVar \u2014 no read-arc) and computes the modified Branin-Hoo objective (minimization, global min ~0.3979). Emits `obs = {a, d, z}` as the gathered element.",
        "executionSpec": {
          "backendType": "python",
          "entrypoint": "main.py",
          "config": {
            "python": "python3",
            "requirements": [],
            "virtualenv": false,
            "sdk": false,
            "inherit_env": true,
            "env": {}
          }
        },
        "output": {
          "id": "out",
          "label": "Observation",
          "fields": [
            {
              "name": "obs",
              "label": "Observation",
              "kind": "json",
              "required": true
            }
          ]
        }
      }
    },
    {
      "id": "gather",
      "type": "automated_step",
      "slug": "gather",
      "parentId": "lp",
      "position": {
        "x": 920,
        "y": 80
      },
      "data": {
        "type": "automated_step",
        "label": "Fold evals into observations",
        "description": "Reads the gathered Map collection `evals[*].obs` (the `[*]` boundary is mandatory) plus the prior incumbent (`bo.f_best`, `bo.best_a`, `bo.best_d`), folds the new evaluations into the observation set, and updates the incumbent. Its outputs drive the loop accumulator mergeExprs.",
        "executionSpec": {
          "backendType": "python",
          "entrypoint": "main.py",
          "config": {
            "python": "python3",
            "requirements": [],
            "virtualenv": false,
            "sdk": true,
            "inherit_env": true,
            "env": {}
          }
        },
        "output": {
          "id": "out",
          "label": "Folded",
          "fields": [
            {
              "name": "merged",
              "label": "New observations",
              "kind": "json",
              "required": true
            },
            {
              "name": "new_f_best",
              "label": "Updated f_best",
              "kind": "number",
              "required": true
            },
            {
              "name": "new_best_a",
              "label": "Updated best a",
              "kind": "number",
              "required": true
            },
            {
              "name": "new_best_d",
              "label": "Updated best d",
              "kind": "number",
              "required": true
            }
          ]
        }
      }
    },
    {
      "id": "end",
      "type": "end",
      "position": {
        "x": 1440,
        "y": 200
      },
      "data": {
        "type": "end",
        "label": "Report best",
        "resultMapping": [
          {
            "targetField": "best_a",
            "expression": "bo.best_a"
          },
          {
            "targetField": "best_d",
            "expression": "bo.best_d"
          },
          {
            "targetField": "best_z",
            "expression": "bo.f_best"
          },
          {
            "targetField": "iterations",
            "expression": "bo.iteration"
          }
        ]
      }
    }
  ],
