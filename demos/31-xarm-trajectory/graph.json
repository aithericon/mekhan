{
  "nodes": [
    {
      "id": "start",
      "type": "start",
      "position": { "x": 40, "y": 160 },
      "data": {
        "type": "start",
        "label": "Start",
        "processName": "xArm Trajectory Action",
        "initial": {
          "id": "in",
          "label": "Begin",
          "fields": []
        }
      }
    },
    {
      "id": "move",
      "type": "automated_step",
      "slug": "move",
      "position": { "x": 320, "y": 160 },
      "data": {
        "type": "automated_step",
        "label": "Move (trajectory action)",
        "description": "ROS `send_action_goal` to `/xarm6_traj_controller/follow_joint_trajectory` (`control_msgs/action/FollowJointTrajectory`). Commands the simulated xArm 6's ros2_control trajectory controller with a nested FollowJointTrajectory goal — a `trajectory` carrying `joint_names` (six joints) and one `points` entry (`positions` [0,-0.3,-0.3,0,0.6,0] reachable, `time_from_start` 3s). This is the PRODUCTION path: real industrial arms are driven through the joint_trajectory_controller's FollowJointTrajectory action, not through MoveIt planner services. The goal is authored as free-form JSON in `config.fields` and passed to rosbridge verbatim (no mapper involvement; nested array-of-structs is fine). Success is IMPLICIT — the backend only succeeds when GoalStatus == 4 (SUCCEEDED), so the net only proceeds past this step if the arm reached the commanded configuration; otherwise the net fails. The terminal action RESULT (`error_code`, `error_string`) rides `stdout_tail` and is NOT a referenceable output, so nothing downstream maps from this node's result. Runs on an `xarm_fleet` runner that satisfies `ros.robot_model == xarm6`; the rosbridge endpoint is runner-local (`EXECUTOR_ROS__WS_URL`). The embedded `interface_typedefs` (flat FollowJointTrajectory_Result) let the deriver shape the output port live for this non-bundled action.",
        "deploymentModel": {
          "mode": "executor",
          "capacity": { "alias": "xarm_fleet" }
        },
        "requirements": {
          "constraints": [
            { "capability": "ros", "field": "robot_model", "op": "eq", "value": "xarm6" }
          ]
        },
        "executionSpec": {
          "backendType": "ros",
          "config": {
            "operation": "send_action_goal",
            "interface_name": "/xarm6_traj_controller/follow_joint_trajectory",
            "interface_type": "control_msgs/action/FollowJointTrajectory",
            "fields": {
              "trajectory": {
                "joint_names": ["joint1", "joint2", "joint3", "joint4", "joint5", "joint6"],
                "points": [
                  { "positions": [0.0, -0.3, -0.3, 0.0, 0.6, 0.0], "time_from_start": { "sec": 3, "nanosec": 0 } }
                ]
              }
            },
            "interface_typedefs": [
              { "type": "control_msgs/FollowJointTrajectory_Result", "fieldnames": ["error_code", "error_string"], "fieldtypes": ["int32", "string"], "fieldarraylen": [-1, -1] }
            ]
          }
        },
        "output": {
          "id": "out",
          "label": "Output",
          "fields": [
            { "name": "error_code", "label": "Error code", "kind": "number" },
            { "name": "error_string", "label": "Error string", "kind": "text" },
            { "name": "feedback_count", "label": "Feedback count", "kind": "number" }
          ]
        },
        "retryPolicy": { "maxRetries": 0, "backoff": "immediate" }
      }
    },
    {
      "id": "read_state",
      "type": "automated_step",
      "slug": "read_state",
      "position": { "x": 600, "y": 160 },
      "data": {
        "type": "automated_step",
        "label": "Read Joint State",
        "description": "ROS `await_topic` on `/joint_states` (`sensor_msgs/msg/JointState`). Blocks for the next joint-state message the broadcaster publishes after the move, capturing where the arm ended up. `await_topic` derives its output port from the message type — JointState's fields land at the TOP LEVEL: `header` (nested), `name` (string[]), `position`/`velocity`/`effort` (float64[]). These ARRAY output fields are the first the platform derives from a live ROS message (the turtle's Pose was all scalars); each maps to a Json port field carrying a JSON-Schema array override the variable picker can descend into. End maps `joint_names = {{ read_state.name }}` and `positions = {{ read_state.position }}` onto the instance result. Same `xarm_fleet` placement + Requirement.",
        "deploymentModel": {
          "mode": "executor",
          "capacity": { "alias": "xarm_fleet" }
        },
        "requirements": {
          "constraints": [
            { "capability": "ros", "field": "robot_model", "op": "eq", "value": "xarm6" }
          ]
        },
        "executionSpec": {
          "backendType": "ros",
          "config": {
            "operation": "await_topic",
            "interface_name": "/joint_states",
            "interface_type": "sensor_msgs/msg/JointState",
            "fields": {},
            "interface_typedefs": [
              { "type": "sensor_msgs/JointState", "fieldnames": ["header", "name", "position", "velocity", "effort"], "fieldtypes": ["std_msgs/Header", "string", "double", "double", "double"], "fieldarraylen": [-1, 0, 0, 0, 0] },
              { "type": "std_msgs/Header", "fieldnames": ["stamp", "frame_id"], "fieldtypes": ["builtin_interfaces/Time", "string"], "fieldarraylen": [-1, -1] },
              { "type": "builtin_interfaces/Time", "fieldnames": ["sec", "nanosec"], "fieldtypes": ["int32", "uint32"], "fieldarraylen": [-1, -1] }
            ]
          }
        },
        "output": {
          "id": "out",
          "label": "Output",
          "fields": [
            { "name": "header", "label": "Header", "kind": "json", "schema": { "type": "object", "properties": { "stamp": {}, "frame_id": { "type": "string" } } } },
            { "name": "name", "label": "Name", "kind": "json", "schema": { "type": "array", "items": { "type": "string" } } },
            { "name": "position", "label": "Position", "kind": "json", "schema": { "type": "array", "items": { "type": ["number", "null"] } } },
            { "name": "velocity", "label": "Velocity", "kind": "json", "schema": { "type": "array", "items": { "type": ["number", "null"] } } },
            { "name": "effort", "label": "Effort", "kind": "json", "schema": { "type": "array", "items": { "type": ["number", "null"] } } }
          ]
        },
        "retryPolicy": { "maxRetries": 0, "backoff": "immediate" }
      }
    },
    {
      "id": "end",
      "type": "end",
      "position": { "x": 880, "y": 160 },
      "data": {
        "type": "end",
        "label": "Done",
        "resultMapping": [
          { "targetField": "joint_names", "expression": "read_state.name" },
          { "targetField": "positions", "expression": "read_state.position" },
          { "targetField": "executed", "expression": "true" }
        ]
      }
    }
  ],
  "edges": [
    { "id": "e_start_move", "source": "start", "target": "move", "targetHandle": "in", "type": "sequence" },
    { "id": "e_move_read", "source": "move", "target": "read_state", "targetHandle": "in", "type": "sequence" },
    { "id": "e_read_end", "source": "read_state", "target": "end", "targetHandle": "in", "type": "sequence" }
  ]
}
