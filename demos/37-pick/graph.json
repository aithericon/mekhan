{
  "nodes": [
    {
      "id": "start",
      "type": "start",
      "position": { "x": 0, "y": 68 },
      "data": {
        "type": "start",
        "label": "Start",
        "processName": "xArm Pick (approach → execute → grasp)",
        "initial": {
          "id": "in",
          "label": "Pick Input",
          "fields": [
            { "name": "grasp_pose", "label": "Grasp pose (geometry_msgs/Pose)", "kind": "json", "required": true },
            { "name": "approach_pose", "label": "Approach pose (geometry_msgs/Pose, above the sample)", "kind": "json", "required": true },
            { "name": "object_id", "label": "Collision object id to attach", "kind": "text", "required": true }
          ]
        }
      }
    },
    {
      "id": "plan_pose",
      "type": "automated_step",
      "slug": "plan_pose",
      "position": { "x": 290, "y": 34 },
      "data": {
        "type": "automated_step",
        "label": "Plan to Approach Pose (MoveIt)",
        "description": "ROS `call_service` to `/plan_to_pose` (`aithericon_motion_bridge/srv/PlanToPose`) — plan a joint trajectory to the caller-supplied APPROACH pose (above the sample, not inside the collision object — a goal pose inside the object fails IK under avoid_collisions). The approach pose is spliced as the BARE whole-object placeholder `{{ start.approach_pose }}` so the backend re-parses the pure placeholder into the typed `geometry_msgs/Pose` with no reshaping. The bridge calls MoveIt's OWN services (`/compute_ik` then `/plan_kinematic_path`) and RETURNS the planned trajectory plus the typed metrics sidecar the Decision gate keys off. Runs on an `xarm_fleet` runner satisfying `ros.robot_model == xarm6`; the embedded `interface_typedefs` let the deriver shape the output port live for this non-bundled service.",
        "deploymentModel": { "mode": "executor", "capacity": { "alias": "xarm_fleet" } },
        "requirements": {
          "constraints": [
            { "capability": "ros", "field": "robot_model", "op": "eq", "value": "xarm6" }
          ]
        },
        "executionSpec": {
          "backendType": "ros",
          "config": {
            "operation": "call_service",
            "interface_name": "/plan_to_pose",
            "interface_type": "aithericon_motion_bridge/srv/PlanToPose",
            "fields": {
              "target": "{{ start.approach_pose }}",
              "group": "xarm6",
              "frame_id": "link_base",
              "allowed_planning_time": 5.0,
              "num_planning_attempts": 10
            },
            "interface_typedefs": [
              {
                "type": "aithericon_motion_bridge/PlanToPose_Request",
                "fieldnames": ["target", "group", "frame_id", "allowed_planning_time", "num_planning_attempts"],
                "fieldtypes": ["geometry_msgs/Pose", "string", "string", "double", "int32"],
                "fieldarraylen": [-1, -1, -1, -1, -1]
              },
              {
                "type": "aithericon_motion_bridge/PlanToPose_Response",
                "fieldnames": ["success", "trajectory", "planning_time", "point_count", "total_duration", "error_code", "error_message"],
                "fieldtypes": ["boolean", "string", "double", "int32", "double", "int32", "string"],
                "fieldarraylen": [-1, -1, -1, -1, -1, -1, -1]
              }
            ]
          }
        },
        "output": {
          "id": "out",
          "label": "Output",
          "fields": [
            { "name": "trajectory", "label": "Trajectory (opaque JSON-encoded JointTrajectory)", "kind": "text" },
            { "name": "success", "label": "Success", "kind": "bool" },
            { "name": "planning_time", "label": "Planning time (s)", "kind": "number" },
            { "name": "point_count", "label": "Point count", "kind": "number" },
            { "name": "total_duration", "label": "Total duration (s)", "kind": "number" }
          ]
        },
        "retryPolicy": { "maxRetries": 0, "backoff": "immediate" }
      }
    },
    {
      "id": "gate",
      "type": "decision",
      "slug": "gate",
      "position": { "x": 600, "y": 80 },
      "data": {
        "type": "decision",
        "label": "Approach plan acceptable?",
        "description": "Compiler-checked gate on the typed metrics sidecar from `plan_pose`. Accept only a successful plan with at least one trajectory point and a total duration within 30s; everything else routes to `end-rejected` (execute + grasp never fire). Each `<slug>.<field>` ref is resolved against `plan_pose`'s declared output port at compile time — a sidecar field-name typo fails pre-publish.",
        "conditions": [
          {
            "edgeId": "branch-accept",
            "label": "Accept",
            "guard": "plan_pose.success == true && plan_pose.point_count > 0 && plan_pose.total_duration <= 30.0"
          }
        ],
        "defaultBranch": "default"
      }
    },
    {
      "id": "execute",
      "type": "automated_step",
      "slug": "execute",
      "position": { "x": 910, "y": 144 },
      "data": {
        "type": "automated_step",
        "label": "Execute Approach Trajectory (Path B)",
        "description": "ROS `send_action_goal` to `/xarm6_traj_controller/follow_joint_trajectory` (`control_msgs/action/FollowJointTrajectory`) — the already-shipped Path B execution primitive. The planned trajectory is spliced verbatim as the BARE whole-object placeholder `{{ plan_pose.trajectory }}` (the only content of the `trajectory` field, so the backend's `is_pure_placeholder` path re-parses the rendered JSON object and adopts the typed value with zero reshaping). The action's terminal RESULT rides `stdout_tail`, NOT outputs — so `error_code` is NOT mapped here. Runs on the same `xarm_fleet` runner.",
        "deploymentModel": { "mode": "executor", "capacity": { "alias": "xarm_fleet" } },
        "requirements": {
          "constraints": [
            { "capability": "ros", "field": "robot_model", "op": "eq", "value": "xarm6" }
          ]
        },
        "executionSpec": {
          "backendType": "ros",
          "config": {
            "operation": "send_action_goal",
            "interface_name": "/xarm6_traj_controller/follow_joint_trajectory",
            "interface_type": "control_msgs/action/FollowJointTrajectory",
            "fields": {
              "trajectory": "{{ plan_pose.trajectory }}"
            },
            "interface_typedefs": [
              {
                "type": "control_msgs/FollowJointTrajectory_Result",
                "fieldnames": ["error_code", "error_string"],
                "fieldtypes": ["int32", "string"],
                "fieldarraylen": [-1, -1]
              }
            ]
          }
        },
        "output": {
          "id": "out",
          "label": "Output",
          "fields": [
            { "name": "feedback_count", "label": "Feedback count", "kind": "number" }
          ]
        },
        "retryPolicy": { "maxRetries": 0, "backoff": "immediate" }
      }
    },
    {
      "id": "descend_plan",
      "type": "automated_step",
      "slug": "descend_plan",
      "position": { "x": 1220, "y": 94 },
      "data": {
        "type": "automated_step",
        "label": "Plan Cartesian Descent to Grasp Pose",
        "description": "ROS `call_service` to `/plan_cartesian` (`aithericon_motion_bridge/srv/PlanCartesian`) — a straight-line Cartesian descent from the current (approach) pose toward the caller's `grasp_pose`. `waypoints` is a single-element array whose lone entry is the BARE whole-object placeholder `{{ start.grasp_pose }}` (the array literal is rendered element-wise; a pure placeholder resolving to an object is adopted verbatim as the typed `geometry_msgs/Pose`). With `avoid_collisions` on, `/compute_cartesian_path` solves the path only as far as it stays collision-free and stops at the sample's surface (`fraction < 1.0`), so the gripper descends to a real pre-grasp at the box top instead of attaching from 14 cm up. The bridge time-parameterizes the geometric path before returning so Path B can execute it.",
        "deploymentModel": { "mode": "executor", "capacity": { "alias": "xarm_fleet" } },
        "requirements": {
          "constraints": [
            { "capability": "ros", "field": "robot_model", "op": "eq", "value": "xarm6" }
          ]
        },
        "executionSpec": {
          "backendType": "ros",
          "config": {
            "operation": "call_service",
            "interface_name": "/plan_cartesian",
            "interface_type": "aithericon_motion_bridge/srv/PlanCartesian",
            "fields": {
              "waypoints": ["{{ start.grasp_pose }}"],
              "group": "xarm6",
              "frame_id": "link_base",
              "eef_step": 0.01,
              "jump_threshold": 0.0,
              "allowed_planning_time": 5.0
            },
            "interface_typedefs": [
              {
                "type": "aithericon_motion_bridge/PlanCartesian_Request",
                "fieldnames": ["waypoints", "group", "frame_id", "eef_step", "jump_threshold", "allowed_planning_time"],
                "fieldtypes": ["geometry_msgs/Pose", "string", "string", "double", "double", "double"],
                "fieldarraylen": [0, -1, -1, -1, -1, -1]
              },
              {
                "type": "aithericon_motion_bridge/PlanCartesian_Response",
                "fieldnames": ["success", "trajectory", "planning_time", "point_count", "total_duration", "fraction", "error_code", "error_message"],
                "fieldtypes": ["boolean", "string", "double", "int32", "double", "double", "int32", "string"],
                "fieldarraylen": [-1, -1, -1, -1, -1, -1, -1, -1]
              }
            ]
          }
        },
        "output": {
          "id": "out",
          "label": "Output",
          "fields": [
            { "name": "trajectory", "label": "Trajectory (opaque JSON-encoded JointTrajectory)", "kind": "text" },
            { "name": "success", "label": "Success", "kind": "bool" },
            { "name": "planning_time", "label": "Planning time (s)", "kind": "number" },
            { "name": "point_count", "label": "Point count", "kind": "number" },
            { "name": "total_duration", "label": "Total duration (s)", "kind": "number" },
            { "name": "fraction", "label": "Fraction solved", "kind": "number" }
          ]
        },
        "retryPolicy": { "maxRetries": 0, "backoff": "immediate" }
      }
    },
    {
      "id": "descend_gate",
      "type": "decision",
      "slug": "descend_gate",
      "position": { "x": 1530, "y": 150 },
      "data": {
        "type": "decision",
        "label": "Descent plan acceptable?",
        "description": "Gate on the Cartesian descent. Accept any successful solve that produced at least one trajectory point — a PARTIAL solve (`fraction < 1.0`: the gripper stopped at the sample surface) is EXPECTED and fine. Only a hard planning failure or an empty path routes to `end-rejected`. `total_duration` is bounded at 30s as a runaway guard.",
        "conditions": [
          {
            "edgeId": "branch-accept",
            "label": "Accept",
            "guard": "descend_plan.success == true && descend_plan.point_count > 0 && descend_plan.total_duration <= 30.0"
          }
        ],
        "defaultBranch": "default"
      }
    },
    {
      "id": "descend_exec",
      "type": "automated_step",
      "slug": "descend_exec",
      "position": { "x": 1840, "y": 154 },
      "data": {
        "type": "automated_step",
        "label": "Execute Descent Trajectory (Path B)",
        "description": "ROS `send_action_goal` to `/xarm6_traj_controller/follow_joint_trajectory` — execute the time-parameterized Cartesian descent from `descend_plan`, spliced verbatim as `{{ descend_plan.trajectory }}`. Lowers the gripper from the approach pose down to the pre-grasp at the sample before the atomic grasp fires. Same `xarm_fleet` runner.",
        "deploymentModel": { "mode": "executor", "capacity": { "alias": "xarm_fleet" } },
        "requirements": {
          "constraints": [
            { "capability": "ros", "field": "robot_model", "op": "eq", "value": "xarm6" }
          ]
        },
        "executionSpec": {
          "backendType": "ros",
          "config": {
            "operation": "send_action_goal",
            "interface_name": "/xarm6_traj_controller/follow_joint_trajectory",
            "interface_type": "control_msgs/action/FollowJointTrajectory",
            "fields": {
              "trajectory": "{{ descend_plan.trajectory }}"
            },
            "interface_typedefs": [
              {
                "type": "control_msgs/FollowJointTrajectory_Result",
                "fieldnames": ["error_code", "error_string"],
                "fieldtypes": ["int32", "string"],
                "fieldarraylen": [-1, -1]
              }
            ]
          }
        },
        "output": {
          "id": "out",
          "label": "Output",
          "fields": [
            { "name": "feedback_count", "label": "Feedback count", "kind": "number" }
          ]
        },
        "retryPolicy": { "maxRetries": 0, "backoff": "immediate" }
      }
    },
    {
      "id": "grasp",
      "type": "automated_step",
      "slug": "grasp",
      "position": { "x": 2150, "y": 144 },
      "data": {
        "type": "automated_step",
        "label": "Grasp (atomic close + attach)",
        "description": "ROS `call_service` to `/grasp` (`aithericon_motion_bridge/srv/Grasp`) — the atomic compound op: actuate the `xarm_gripper` group closed THEN `AttachedCollisionObject` ADD of the caller-supplied `object_id` on `/apply_planning_scene`, both in one service call, returning only after both complete. `object_id` is spliced as the BARE whole-object placeholder `{{ start.object_id }}`. Fires AFTER the Cartesian descent (`descend_exec`) has lowered the gripper to the pre-grasp at the sample surface, so the attach happens with the gripper aligned over the object rather than 14 cm up. Response `{success, attached, error_message}`; `attached==true` proves the object is now part of the robot's collision body. Runs on the same `xarm_fleet` runner.",
        "deploymentModel": { "mode": "executor", "capacity": { "alias": "xarm_fleet" } },
        "requirements": {
          "constraints": [
            { "capability": "ros", "field": "robot_model", "op": "eq", "value": "xarm6" }
          ]
        },
        "executionSpec": {
          "backendType": "ros",
          "config": {
            "operation": "call_service",
            "interface_name": "/grasp",
            "interface_type": "aithericon_motion_bridge/srv/Grasp",
            "fields": {
              "object_id": "{{ start.object_id }}",
              "width": 0.0,
              "effort": 50.0
            },
            "interface_typedefs": [
              {
                "type": "aithericon_motion_bridge/Grasp_Request",
                "fieldnames": ["object_id", "width", "effort"],
                "fieldtypes": ["string", "double", "double"],
                "fieldarraylen": [-1, -1, -1]
              },
              {
                "type": "aithericon_motion_bridge/Grasp_Response",
                "fieldnames": ["success", "attached", "error_message"],
                "fieldtypes": ["boolean", "boolean", "string"],
                "fieldarraylen": [-1, -1, -1]
              }
            ]
          }
        },
        "output": {
          "id": "out",
          "label": "Output",
          "fields": [
            { "name": "success", "label": "Success", "kind": "bool" },
            { "name": "attached", "label": "Attached", "kind": "bool" }
          ]
        },
        "retryPolicy": { "maxRetries": 0, "backoff": "immediate" }
      }
    },
    {
      "id": "retreat_plan",
      "type": "automated_step",
      "slug": "retreat_plan",
      "position": { "x": 2460, "y": 114 },
      "data": {
        "type": "automated_step",
        "label": "Plan Retreat to Approach (MoveIt)",
        "description": "ROS `call_service` to `/plan_to_pose` (`aithericon_motion_bridge/srv/PlanToPose`) — a JOINT-SPACE plan that lifts the arm (sample attached) back up to the approach pose. A joint-space plan is used here rather than a straight-line cartesian one because the cartesian solver stalls (fraction 0) stepping out of a deep grasp/insert config, whereas `/plan_kinematic_path` reliably finds a path to the approach pose (which was just planned TO at the start of the subworkflow, so it is known reachable). The attached sample's `touch_links` keep the closed gripper from self-colliding. Returns the arm to a high neutral configuration so the NEXT job's /compute_ik seeds from a sane pose.",
        "deploymentModel": { "mode": "executor", "capacity": { "alias": "xarm_fleet" } },
        "requirements": {
          "constraints": [
            { "capability": "ros", "field": "robot_model", "op": "eq", "value": "xarm6" }
          ]
        },
        "executionSpec": {
          "backendType": "ros",
          "config": {
            "operation": "call_service",
            "interface_name": "/plan_to_pose",
            "interface_type": "aithericon_motion_bridge/srv/PlanToPose",
            "fields": {
              "target": "{{ start.approach_pose }}",
              "group": "xarm6",
              "frame_id": "link_base",
              "allowed_planning_time": 5.0,
              "num_planning_attempts": 10
            },
            "interface_typedefs": [
              {
                "type": "aithericon_motion_bridge/PlanToPose_Request",
                "fieldnames": ["target", "group", "frame_id", "allowed_planning_time", "num_planning_attempts"],
                "fieldtypes": ["geometry_msgs/Pose", "string", "string", "double", "int32"],
                "fieldarraylen": [-1, -1, -1, -1, -1]
              },
              {
                "type": "aithericon_motion_bridge/PlanToPose_Response",
                "fieldnames": ["success", "trajectory", "planning_time", "point_count", "total_duration", "error_code", "error_message"],
                "fieldtypes": ["boolean", "string", "double", "int32", "double", "int32", "string"],
                "fieldarraylen": [-1, -1, -1, -1, -1, -1, -1]
              }
            ]
          }
        },
        "output": {
          "id": "out",
          "label": "Output",
          "fields": [
            { "name": "trajectory", "label": "Trajectory (opaque JSON-encoded JointTrajectory)", "kind": "text" },
            { "name": "success", "label": "Success", "kind": "bool" },
            { "name": "planning_time", "label": "Planning time (s)", "kind": "number" },
            { "name": "point_count", "label": "Point count", "kind": "number" },
            { "name": "total_duration", "label": "Total duration (s)", "kind": "number" }
          ]
        },
        "retryPolicy": { "maxRetries": 0, "backoff": "immediate" }
      }
    },
    {
      "id": "retreat_gate",
      "type": "decision",
      "slug": "retreat_gate",
      "position": { "x": 2770, "y": 160 },
      "data": {
        "type": "decision",
        "label": "Retreat plan acceptable?",
        "description": "Best-effort gate on the lift-off. Accept a successful solve with at least one point → execute the retreat. A failed/empty solve falls through to `end-done` ANYWAY (default branch): the grasp already succeeded, so picked stays true — the lift is polish, not a correctness gate. `total_duration` bounded at 30s.",
        "conditions": [
          {
            "edgeId": "branch-accept",
            "label": "Accept",
            "guard": "retreat_plan.success == true && retreat_plan.point_count > 0 && retreat_plan.total_duration <= 30.0"
          }
        ],
        "defaultBranch": "default"
      }
    },
    {
      "id": "retreat_exec",
      "type": "automated_step",
      "slug": "retreat_exec",
      "position": { "x": 3080, "y": 199 },
      "data": {
        "type": "automated_step",
        "label": "Execute Retreat Trajectory (Path B)",
        "description": "ROS `send_action_goal` to `/xarm6_traj_controller/follow_joint_trajectory` — execute the time-parameterized retreat from `retreat_plan`, spliced verbatim as `{{ retreat_plan.trajectory }}`. Lifts the gripper (carrying the sample) back to the approach pose. Same `xarm_fleet` runner.",
        "deploymentModel": { "mode": "executor", "capacity": { "alias": "xarm_fleet" } },
        "requirements": {
          "constraints": [
            { "capability": "ros", "field": "robot_model", "op": "eq", "value": "xarm6" }
          ]
        },
        "executionSpec": {
          "backendType": "ros",
          "config": {
            "operation": "send_action_goal",
            "interface_name": "/xarm6_traj_controller/follow_joint_trajectory",
            "interface_type": "control_msgs/action/FollowJointTrajectory",
            "fields": {
              "trajectory": "{{ retreat_plan.trajectory }}"
            },
            "interface_typedefs": [
              {
                "type": "control_msgs/FollowJointTrajectory_Result",
                "fieldnames": ["error_code", "error_string"],
                "fieldtypes": ["int32", "string"],
                "fieldarraylen": [-1, -1]
              }
            ]
          }
        },
        "output": {
          "id": "out",
          "label": "Output",
          "fields": [
            { "name": "feedback_count", "label": "Feedback count", "kind": "number" }
          ]
        },
        "retryPolicy": { "maxRetries": 0, "backoff": "immediate" }
      }
    },
    {
      "id": "end-done",
      "type": "end",
      "position": { "x": 3390, "y": 158 },
      "data": {
        "type": "end",
        "label": "Picked",
        "resultMapping": [
          { "targetField": "picked", "expression": "grasp.success" },
          { "targetField": "object_id", "expression": "start.object_id" }
        ]
      }
    },
    {
      "id": "end-rejected",
      "type": "end",
      "position": { "x": 1850, "y": 0 },
      "data": {
        "type": "end",
        "label": "Plan Rejected",
        "resultMapping": [
          { "targetField": "picked", "expression": "false" },
          { "targetField": "object_id", "expression": "start.object_id" }
        ]
      }
    }
  ],
  "edges": [
    { "id": "e_start_plan", "source": "start", "target": "plan_pose", "targetHandle": "in", "type": "sequence" },
    { "id": "e_plan_gate", "source": "plan_pose", "target": "gate", "targetHandle": "in", "type": "sequence" },
    { "id": "e_gate_execute", "source": "gate", "target": "execute", "targetHandle": "in", "sourceHandle": "branch-accept", "label": "Accept", "type": "conditional" },
    { "id": "e_gate_rejected", "source": "gate", "target": "end-rejected", "targetHandle": "in", "sourceHandle": "default", "label": "Reject", "type": "conditional" },
    { "id": "e_execute_descplan", "source": "execute", "target": "descend_plan", "targetHandle": "in", "type": "sequence" },
    { "id": "e_descplan_descgate", "source": "descend_plan", "target": "descend_gate", "targetHandle": "in", "type": "sequence" },
    { "id": "e_descgate_descexec", "source": "descend_gate", "target": "descend_exec", "targetHandle": "in", "sourceHandle": "branch-accept", "label": "Accept", "type": "conditional" },
    { "id": "e_descgate_rejected", "source": "descend_gate", "target": "end-rejected", "targetHandle": "in", "sourceHandle": "default", "label": "Reject", "type": "conditional" },
    { "id": "e_descexec_grasp", "source": "descend_exec", "target": "grasp", "targetHandle": "in", "type": "sequence" },
    { "id": "e_grasp_retreatplan", "source": "grasp", "target": "retreat_plan", "targetHandle": "in", "type": "sequence" },
    { "id": "e_retreatplan_retreatgate", "source": "retreat_plan", "target": "retreat_gate", "targetHandle": "in", "type": "sequence" },
    { "id": "e_retreatgate_retreatexec", "source": "retreat_gate", "target": "retreat_exec", "targetHandle": "in", "sourceHandle": "branch-accept", "label": "Accept", "type": "conditional" },
    { "id": "e_retreatgate_done", "source": "retreat_gate", "target": "end-done", "targetHandle": "in", "sourceHandle": "default", "label": "Skip", "type": "conditional" },
    { "id": "e_retreatexec_done", "source": "retreat_exec", "target": "end-done", "targetHandle": "in", "type": "sequence" }
  ]
}
