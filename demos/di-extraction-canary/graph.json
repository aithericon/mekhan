{
  "nodes": [
    {
      "id": "trigger-intake",
      "type": "trigger",
      "position": { "x": 0, "y": 125 },
      "data": {
        "type": "trigger",
        "label": "Intake API",
        "source": {
          "kind": "manual",
          "form": []
        },
        "concurrency": "allow",
        "payloadMapping": [
          {
            "targetField": "document_file",
            "expression": "document_file"
          },
          {
            "targetField": "document_id",
            "expression": "document_id"
          }
        ],
        "enabled": true
      }
    },
    {
      "id": "start",
      "type": "start",
      "position": { "x": 250, "y": 98 },
      "data": {
        "type": "start",
        "label": "Start",
        "processName": "DI canary — {{ document_id }}",
        "initial": {
          "id": "in",
          "label": "Document Intake",
          "fields": [
            {
              "name": "document_file",
              "label": "Document (PDF, PNG, JPG)",
              "kind": "file",
              "required": true,
              "accept": "application/pdf,image/png,image/jpeg,image/webp"
            },
            {
              "name": "document_id",
              "label": "Document ID",
              "kind": "text",
              "required": true
            }
          ]
        }
      }
    },
    {
      "id": "extract",
      "type": "agent",
      "position": { "x": 540, "y": 44 },
      "data": {
        "type": "agent",
        "label": "Extract (vision-only, single call)",
        "description": "Classification + extraction in ONE vision call. No OCR layer, no per-field citations, no bbox grounding. Mirrors the clinic's `t_extract` transition (Vision, qwen3.6:35b-a3b). Locally we use llama3.2-vision:11b as the vision substitute — swap to the heavier MoE for parity benchmarks.",
        "model": {
          "provider": "ollama",
          "model": "llama3.2-vision:11b",
          "baseUrl": "http://localhost:11434",
          "temperature": 0,
          "maxTokens": 4096
        },
        "userPrompt": "Analyze this medical document image and return the JSON object as specified.",
        "systemPrompt": "You are a medical document analyzer. Extract structured fields from the input image. Return JSON conforming to this schema: { document_type, document_date, fields[{key, value, confidence}], suggested_actions[], confidence_score, page_count }. Use snake_case enum variants for document_type: lab_result | referral_letter | prescription | insurance_form | imaging_report | discharge_summary | consultation_note | invoice | consent_form | other. document_date must be YYYY-MM-DD or null. Each field's confidence is a float 0.0-1.0. Return only the JSON object, no commentary.",
        "responseFormat": {
          "type": "json_schema",
          "schema": {
            "$ref": "#/definitions/RawExtraction"
          }
        },
        "images": [
          {
            "path": "{{ start.document_file }}"
          }
        ],
        "maxTurns": 1
      }
    },
    {
      "id": "validate",
      "type": "automated_step",
      "position": { "x": 870, "y": 0 },
      "data": {
        "type": "automated_step",
        "label": "Validate (shape coerce)",
        "description": "Python analogue of the canary's Rhai `t_validate` transition. Shape-coerces the raw extraction into a defaults-filled ExtractionResult: missing/wrong-typed fields fall back to safe defaults; ai_model is stamped from the upstream config.",
        "executionSpec": {
          "backendType": "python",
          "entrypoint": "main.py",
          "config": {
            "python": "python3",
            "requirements": [],
            "virtualenv": false,
            "sdk": true,
            "inherit_env": true,
            "env": {}
          }
        },
        "output": {
          "id": "out",
          "label": "ExtractionResult",
          "fields": [
            {
              "name": "document_type",
              "label": "Document type",
              "kind": "text",
              "required": true
            },
            {
              "name": "document_date",
              "label": "Document date",
              "kind": "text",
              "required": false
            },
            {
              "name": "fields",
              "label": "Fields",
              "kind": "json",
              "required": true
            },
            {
              "name": "suggested_actions",
              "label": "Suggested actions",
              "kind": "json",
              "required": true
            },
            {
              "name": "confidence_score",
              "label": "Confidence",
              "kind": "number",
              "required": true
            },
            {
              "name": "page_count",
              "label": "Page count",
              "kind": "number",
              "required": true
            },
            {
              "name": "ai_model",
              "label": "AI model",
              "kind": "text",
              "required": true
            },
            {
              "name": "processing_time_ms",
              "label": "Processing time (ms)",
              "kind": "number",
              "required": true
            }
          ]
        }
      }
    },
    {
      "id": "end-ok",
      "type": "end",
      "position": { "x": 1180, "y": 17 },
      "data": {
        "type": "end",
        "label": "Done",
        "resultMapping": [
          {
            "targetField": "document_id",
            "expression": "start.document_id"
          },
          {
            "targetField": "document_type",
            "expression": "validate.document_type"
          },
          {
            "targetField": "document_date",
            "expression": "validate.document_date"
          },
          {
            "targetField": "fields",
            "expression": "validate.fields"
          },
          {
            "targetField": "suggested_actions",
            "expression": "validate.suggested_actions"
          },
          {
            "targetField": "confidence_score",
            "expression": "validate.confidence_score"
          },
          {
            "targetField": "page_count",
            "expression": "validate.page_count"
          },
          {
            "targetField": "ai_model",
            "expression": "validate.ai_model"
          }
        ]
      }
    }
  ],
  "edges": [
    {
      "id": "e-trigger-start",
      "source": "trigger-intake",
      "target": "start",
      "targetHandle": "in",
      "type": "sequence"
    },
    {
      "id": "e-start-extract",
      "source": "start",
      "target": "extract",
      "targetHandle": "in",
      "type": "sequence"
    },
    {
      "id": "e-extract-validate",
      "source": "extract",
      "target": "validate",
      "targetHandle": "in",
      "type": "sequence",
      "sourceHandle": "out"
    },
    {
      "id": "e-validate-end",
      "source": "validate",
      "target": "end-ok",
      "targetHandle": "in",
      "type": "sequence"
    }
  ],
  "definitions": {
    "RawExtraction": {
      "type": "object",
      "required": [
        "document_type",
        "fields"
      ],
      "properties": {
        "document_type": {
          "type": "string",
          "enum": [
            "lab_result",
            "referral_letter",
            "prescription",
            "insurance_form",
            "imaging_report",
            "discharge_summary",
            "consultation_note",
            "invoice",
            "consent_form",
            "other"
          ]
        },
        "document_date": {
          "type": [
            "string",
            "null"
          ]
        },
        "fields": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "key",
              "value",
              "confidence"
            ],
            "properties": {
              "key": {
                "type": "string"
              },
              "value": {
                "type": "string"
              },
              "confidence": {
                "type": "number",
                "minimum": 0,
                "maximum": 1
              }
            },
            "additionalProperties": false
          }
        },
        "suggested_actions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "confidence_score": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "page_count": {
          "type": "integer",
          "minimum": 1
        }
      },
      "additionalProperties": false
    }
  }
}
