      "data": {
        "type": "start",
        "label": "Start",
        "processName": "Turtle Rotate",
        "initial": { "id": "in", "label": "Begin", "fields": [] }
      }
    },
    {
      "id": "teleport",
      "type": "automated_step",
      "slug": "teleport",
      "position": { "x": 190, "y": 34 },
      "data": {
        "type": "automated_step",
        "label": "Teleport theta=0",
        "description": "ROS `call_service` to `/turtle1/teleport_absolute` (`turtlesim/srv/TeleportAbsolute`). Resets the turtle to a known pose (x=5.5, y=5.5, theta=0.0) so the subsequent `rotate_absolute` action always has a real rotation to perform (theta differs from the target), guaranteeing a non-empty feedback stream. Runs on a `ros_fleet` runner that satisfies `ros.robot_model == turtlesim`.",
        "deploymentModel": {
          "mode": "executor",
          "capacity": { "alias": "ros_fleet" }
        },
        "requirements": {
          "constraints": [
            { "capability": "ros", "field": "robot_model", "op": "eq", "value": "turtlesim" }
          ]
        },
        "executionSpec": {
          "backendType": "ros",
          "config": {
            "operation": "call_service",
            "interface_name": "/turtle1/teleport_absolute",
            "interface_type": "turtlesim/srv/TeleportAbsolute",
            "fields": { "x": 5.5, "y": 5.5, "theta": 0.0 }
          }
        },
        "output": { "id": "out", "label": "Output", "fields": [] },
        "retryPolicy": { "maxRetries": 0, "backoff": "immediate" }
      }
    },
    {
      "id": "rotate",
      "type": "automated_step",
      "slug": "rotate",
      "position": { "x": 500, "y": 7 },
      "data": {
        "type": "automated_step",
        "label": "Rotate (action, streaming feedback)",
        "description": "ROS `send_action_goal` to `/turtle1/rotate_absolute` (`turtlesim/action/RotateAbsolute`). As the turtle rotates, the action server publishes `feedback { remaining }`; the ROS backend dedups the consecutive-identical frames rosbridge emits and streams each DISTINCT feedback as an `item` control token (docs/25) into the node's Control/Out `out` channel `feedback`. On the terminal result it stamps a `close` carrying the total count. The consumer edge to `fold` carries `join: gather`, so the compiler's per-channel gather barrier (sized on that count) re-orders the items and parks the gathered feedback collection `{ output: [{ remaining }, ...] }` on the channel's gathered place, which the downstream `fold` consumer drains — no per-feedback token spams the marking and no feedback rides the node's `outputs` map. The terminal action `delta` rides `stdout_tail` only. Same `ros_fleet` placement + `ros.robot_model == turtlesim` Requirement.",
        "deploymentModel": {
          "mode": "executor",
          "capacity": { "alias": "ros_fleet" }
        },
        "requirements": {
          "constraints": [
            { "capability": "ros", "field": "robot_model", "op": "eq", "value": "turtlesim" }
          ]
        },
        "channels": [
          {
            "name": "feedback",
            "direction": "out",
            "plane": "control",
            "element": { "type": "any" }
          }
        ],
        "executionSpec": {
          "backendType": "ros",
          "config": {
            "operation": "send_action_goal",
            "interface_name": "/turtle1/rotate_absolute",
            "interface_type": "turtlesim/action/RotateAbsolute",
            "fields": { "theta": 0.4 }
          }
        },
        "output": { "id": "out", "label": "Output", "fields": [] },
        "retryPolicy": { "maxRetries": 0, "backoff": "immediate" }
      }
    },
    {
      "id": "fold",
      "type": "automated_step",
      "slug": "fold",
      "position": { "x": 810, "y": 0 },
      "data": {
        "type": "automated_step",
        "label": "Fold Feedback",
        "description": "Reducer job (docs/25 §2 — Fold was never a net concern). Reads the rotate channel's gathered feedback collection (the `{ output: [...] }` envelope merged onto its input token), counts the distinct feedbacks and surfaces the first `remaining`. Replaces the retired in-net `StreamFold` node.",
        "executionSpec": {
          "backendType": "python",
          "entrypoint": "main.py",
          "config": {
            "python": "python3",
            "requirements": [],
            "virtualenv": false,
            "sdk": true,
            "inherit_env": true,
            "env": {}
          }
        },
        "output": {
          "id": "out",
          "label": "Output",
          "fields": [
            { "name": "feedback_count", "label": "Feedback count", "kind": "number" },
            { "name": "rotation_delta", "label": "Rotation delta", "kind": "number" }
          ]
        }
      }
    },
    {
      "id": "end",
      "type": "end",
      "position": { "x": 1120, "y": 4 },
      "data": {
        "type": "end",
        "label": "Done",
        "resultMapping": [
          { "targetField": "feedback_count", "expression": "fold.feedback_count" },
          { "targetField": "rotation_delta", "expression": "fold.rotation_delta" },
          { "targetField": "final_theta", "expression": "0.4" }
        ]
      }
    }
  ],
  "edges": [
    { "id": "e_start_teleport", "source": "start", "target": "teleport", "targetHandle": "in", "type": "sequence" },
    { "id": "e_teleport_rotate", "source": "teleport", "target": "rotate", "targetHandle": "in", "type": "sequence" },
    { "id": "e_rotate_feedback_fold", "source": "rotate", "sourceHandle": "feedback", "target": "fold", "targetHandle": "in", "type": "sequence", "join": "gather" },
    { "id": "e_fold_end", "source": "fold", "target": "end", "targetHandle": "in", "type": "sequence" }
  ]
}
